# Copy to `.env` to override defaults.

# Use the in-memory mock backend (default true so the portal runs with no server).
# Set to false to call the real FastAPI /api/* endpoints.
VITE_USE_MOCK=true

# Base URL for the real API (only used when VITE_USE_MOCK=false).
# Leave as /api when FastAPI serves the built frontend on the same origin.
VITE_API_BASE_URL=/api
