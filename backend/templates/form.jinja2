        };

        function _populateCategoryDropdown() {
            const ddl = document.getElementById('ddlCategory');
            if (!ddl) return;
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            const prevValue = ddl.value;
            ddl.innerHTML = '';
            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = copy.categorySelect;
            ddl.appendChild(defaultOpt);
            CATEGORY_KEYS.forEach(key => {
                const opt = document.createElement('option');
                opt.value = key;
                opt.textContent = copy[CATEGORY_LABEL_KEYS[key]];
                ddl.appendChild(opt);
            });
            ddl.value = prevValue;
        }

        function switchLocalization(isChecked) {
            runtimeActiveLanguage = isChecked ? 'ta' : 'en';
            // Persist choice so the success page can read it and stay in sync
            try { localStorage.setItem('vpa_lang', runtimeActiveLanguage); } catch(e) {}

            // Update the segmented language pills' active state
            const enBtn = document.getElementById('langBtnEn');
            const taBtn = document.getElementById('langBtnTa');
            if (enBtn && taBtn) {
                enBtn.classList.toggle('active', !isChecked);
                taBtn.classList.toggle('active', isChecked);
            }

            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];

            // Header & section titles
            _setText('lbl-dist',         copy.dist);
            _setText('lbl-portal-title', copy.portalTitle);
            _setText('lbl-sec-title',    copy.secTitle);

            // Field labels
            _setText('lbl-name',        copy.name);
            _setText('lbl-phone',       copy.phone);
            _setText('lbl-otp',         copy.otp);
            _setText('lbl-desc',        copy.desc);
            _setText('lbl-upload',      copy.upload);
            _setText('lbl-upload-text', copy.uploadText);
            _setText('lbl-upload-hint', copy.uploadHint);

            // Re-render the inline proceed-choice in the new language (if it's showing)
            const _choiceBox = document.getElementById('actionChoiceInline');
            if (_choiceBox && _choiceBox.style.display !== 'none' && typeof renderChoiceButtons === 'function') {
                renderChoiceButtons();
            }

            // Category dropdown
            _setText('lbl-category', copy.category);
            _populateCategoryDropdown();

            // Slot picker
            _setText('lbl-slot-title',   copy.slotTitle);
            _setText('lbl-slot-loading', copy.slotLoading);
            _setText('lbl-slot-confirm', copy.slotConfirm);
            _setText('lbl-slot-date',    copy.slotSelectDate);

            // Persons attending dropdown
            _setText('lbl-num-persons', copy.numPersonsLabel);
            _setText('opt-persons-1',   copy.optPersons1);
            _setText('opt-persons-2',   copy.optPersons2);
            _setText('opt-persons-3',   copy.optPersons3);
            _setText('opt-persons-4',   copy.optPersons4);
            // Rebuild date picker chips with new language if picker is visible
            if (document.getElementById('slotPickerSection').style.display !== 'none') {
                _buildDatePicker();
            }

            // Recording section
            _setText('lbl-audio',           copy.audio);
            _setText('lbl-audio-hint',      copy.audioHint);
            // Only overwrite label if not currently recording
            const micBtn = document.getElementById('btnStartRecording');
            if (!micBtn || !micBtn.classList.contains('recording')) {
                _setText('lbl-record',          copy.record);
            } else {
                _setText('lbl-record',          copy.stop);
            }
            _setText('lbl-recording-saved', copy.recordingSaved);
            _setText('lbl-delete-rec',      copy.deleteRec);

            // OTP action buttons
            _setText('lbl-send-otp',   copy.sendOtp);
            _setText('lbl-verify-otp', copy.verifyOtp);

            // Input placeholders
            _setAttr('txtName',   'placeholder', copy.placeholderName);
            _setAttr('txtMobile', 'placeholder', copy.placeholderMobile);
            _setAttr('txtDesc',   'placeholder', copy.placeholderDesc);

            // Success modal
            _setText('lbl-modal-title', copy.modalTitle);
            _setText('lbl-modal-body',  copy.modalBody);
            _setText('lbl-modal-id',    copy.modalId);
            _setText('lbl-modal-date',  copy.modalDate);
        }

        async function generateVerificationOtp() {
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];

            if (!validateFormForOTP()) {
                alert(copy.alertFillFields);
                return;
            }

            const phoneField = document.getElementById('txtMobile');
            const errorElement = document.getElementById('errMobile');

            if (!/^[6-9][0-9]{9}$/.test(phoneField.value)) {
                errorElement.innerText = copy.errMob;
                errorElement.style.display = 'block';
                return;
            }
            errorElement.style.display = 'none';

            const sessionToken = document.getElementById('submissionForm').dataset.sessionToken;
            if (!sessionToken) {
                alert(copy.alertSessionMissing);
                return;
            }

            const genBtn = document.getElementById('btnGenOtp');
            genBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ' + copy.sending;
            genBtn.disabled = true;

            try {
                const response = await fetch('/api/v1/otp/request', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ session_token: sessionToken, mobile_number: phoneField.value })
                });

                if (response.ok) {
                    const data = await response.json();
                    document.getElementById('otpVerificationWrapper').style.display = 'block';
                    genBtn.innerHTML = copy.sent;
                    phoneField.disabled = true;

                    if (data.otp_code) {
                        const boxes = document.querySelectorAll('.otp-box');
                        data.otp_code.split('').forEach((d, i) => { if (boxes[i]) boxes[i].value = d; });
                        syncOtpHidden();
                        const msg = document.getElementById('otpStatusMsg');
                        msg.className = 'otp-status-msg error';
                        msg.textContent = `[Dev] OTP auto-filled: ${data.otp_code} — SMS not configured`;
                        msg.style.display = 'block';
                    }

                    document.getElementById('otp0').focus();
                } else {
                    const error = await response.json();
                    const errEl = document.getElementById('errMobile');
                    // Handle structured duplicate-submission error with bilingual messages
                    const detail = error.detail;
                    if (detail && typeof detail === 'object' && detail.code === 'ALREADY_SUBMITTED_TODAY') {
                        const isTamil = runtimeActiveLanguage === 'ta';
                        errEl.innerText = isTamil ? detail.ta : detail.en;
                        errEl.style.color = '#b45309';
                        errEl.style.background = '#fffbeb';
                        errEl.style.padding = '0.5rem 0.65rem';
                        errEl.style.borderRadius = '6px';
                        errEl.style.border = '1px solid #fcd34d';
                        errEl.style.fontSize = '0.82rem';
                        errEl.style.display = 'block';
                    } else {
                        errEl.innerText = (typeof detail === 'string' ? detail : null) || copy.networkError;
                        errEl.style.display = 'block';
                    }
                    genBtn.innerHTML = '<span id="lbl-send-otp">' + copy.sendOtp + '</span>';
                    genBtn.disabled = false;
                }
            } catch (error) {
                const errEl = document.getElementById('errMobile');
                errEl.innerText = copy.networkError;
                errEl.style.display = 'block';
                genBtn.innerHTML = '<span id="lbl-send-otp">' + copy.sendOtp + '</span>';
                genBtn.disabled = false;
            }
        }

        /* ── OTP box keyboard navigation & auto-advance ── */
        function initOtpBoxes() {
            const boxes = Array.from(document.querySelectorAll('.otp-box'));
            boxes.forEach((box, i) => {
                box.addEventListener('input', e => {
                    const val = e.target.value.replace(/[^0-9]/g, '');
                    e.target.value = val ? val[val.length - 1] : '';
                    clearOtpState();
                    if (val && i < 5) boxes[i + 1].focus();
                    syncOtpHidden();
                });

                box.addEventListener('keydown', e => {
                    if (e.key === 'Backspace' && !box.value && i > 0) {
                        boxes[i - 1].value = '';
                        boxes[i - 1].focus();
                        syncOtpHidden();
                    }
                    if (e.key === 'ArrowLeft' && i > 0) boxes[i - 1].focus();
                    if (e.key === 'ArrowRight' && i < 5) boxes[i + 1].focus();
                });

                box.addEventListener('paste', e => {
                    e.preventDefault();
                    const pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '');
                    boxes.forEach((b, j) => { b.value = pasted[j] || ''; });
                    const focusIdx = Math.min(pasted.length, 5);
                    boxes[focusIdx].focus();
                    clearOtpState();
                    syncOtpHidden();
                });
            });
        }

        function syncOtpHidden() {
            const val = Array.from(document.querySelectorAll('.otp-box')).map(b => b.value).join('');
            document.getElementById('txtOtp').value = val;
        }

        function clearOtpState() {
            document.querySelectorAll('.otp-box').forEach(b => b.classList.remove('otp-valid', 'otp-invalid'));
            const msg = document.getElementById('otpStatusMsg');
            msg.className = 'otp-status-msg';
            msg.textContent = '';
        }

        function setOtpBoxState(state, message) {
            // state: 'valid' | 'invalid'
            document.querySelectorAll('.otp-box').forEach(b => {
                b.classList.remove('otp-valid', 'otp-invalid');
                b.classList.add(state === 'valid' ? 'otp-valid' : 'otp-invalid');
            });
            const msg = document.getElementById('otpStatusMsg');
            msg.className = 'otp-status-msg ' + (state === 'valid' ? 'success' : 'error');
            msg.textContent = message;
        }

        function showOtpFieldError(message) {
            setOtpBoxState('invalid', message);
            document.getElementById('otp0').focus();
        }

        async function verifyInputOtp() {
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            syncOtpHidden();
            const otpVal = document.getElementById('txtOtp').value;

            if (otpVal.length !== 6) {
                showOtpFieldError(copy.errOtp);
                return;
            }

            const mobile = document.getElementById('txtMobile').value.trim();
            const verifyBtn = document.getElementById('btnVerifyOtp');
            verifyBtn.disabled = true;
            verifyBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ' + copy.verifying;

            try {
                const response = await fetch('/api/v1/otp/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mobile_number: mobile, otp_code: otpVal }),
                });

                if (response.ok) {
                    isSystemPhoneVerified = true;
                    setOtpBoxState('valid', copy.otpSuccess);
                    verifyBtn.innerHTML = copy.verified;
                    document.querySelectorAll('.otp-box').forEach(b => b.disabled = true);
                    // Reveal the inline proceed-choice (Meeting / Petition / Waitlist)
                    revealActionChoice();
                } else {
                    const err = await response.json();
                    showOtpFieldError(err.detail || copy.errOtp);
                    verifyBtn.disabled = false;
                    verifyBtn.innerHTML = '<span id="lbl-verify-otp">' + copy.verifyOtp + '</span>';
                }
            } catch (e) {
                showOtpFieldError(copy.networkError);
                verifyBtn.disabled = false;
                verifyBtn.innerHTML = '<span id="lbl-verify-otp">' + copy.verifyOtp + '</span>';
            }
        }

        function renderUploadedFiles(input) {
            const previewContainer = document.getElementById('filePreviews');
            const newUploadedFiles = Array.from(input.files);

            newUploadedFiles.forEach(file => {
                if (file.size > 5 * 1024 * 1024) return;

                registeredFileList.push(file);
                const itemIndex = registeredFileList.length - 1;

                const fileBadgeNode = document.createElement('div');
                fileBadgeNode.className = 'file-badge';
                fileBadgeNode.id = `badge-${itemIndex}`;

                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = e => {
                        fileBadgeNode.innerHTML = `
                            <div class="file-badge-inner">
                                <img src="${e.target.result}" class="file-thumb" alt="${file.name}">
                                <div class="file-badge-info">
                                    <strong>${file.name}</strong>
                                    <span>${(file.size/1024).toFixed(1)} KB</span>
                                </div>
                            </div>
                            <button type="button" class="remove-file-btn" onclick="purgeUploadedFile(${itemIndex})"><i class="fa-solid fa-trash-can"></i></button>
                        `;
                    };
                    reader.readAsDataURL(file);
                } else {
                    fileBadgeNode.innerHTML = `
                        <div class="file-badge-inner">
                            <i class="fa-solid fa-file-shield" style="font-size:1.5rem; color:#10b981;"></i>
                            <div class="file-badge-info">
                                <strong>${file.name}</strong>
                                <span>${(file.size/1024).toFixed(1)} KB</span>
                            </div>
                        </div>
                        <button type="button" class="remove-file-btn" onclick="purgeUploadedFile(${itemIndex})"><i class="fa-solid fa-trash-can"></i></button>
                    `;
                }

                previewContainer.appendChild(fileBadgeNode);
            });
            input.value = ""; // Reset input capture target stream
        }

        function purgeUploadedFile(index) {
            document.getElementById(`badge-${index}`).remove();
            registeredFileList[index] = null; // Purge contents cleanly from array space
            validateFormForOTP(); // Re-validate after file removal
        }
        
        // Initialize form validation on page load
        document.addEventListener('DOMContentLoaded', function() {
            initOtpBoxes();
            _populateCategoryDropdown();

            // Disable OTP button initially
            document.getElementById('btnGenOtp').disabled = true;
            
            // Add input event listeners to validate form
            document.getElementById('txtName').addEventListener('input', validateFormForOTP);
            document.getElementById('txtMobile').addEventListener('input', validateFormForOTP);
            document.getElementById('txtDesc').addEventListener('input', validateFormForOTP);
            document.getElementById('ddlCategory').addEventListener('change', validateFormForOTP);
            document.getElementById('fileAttachments').addEventListener('change', function(e) {
                renderUploadedFiles(e.target);
                validateFormForOTP();
            });

        });

        // Detect back-button (bfcache restore) and force a server round-trip
        // so the backend re-validates the session token and redirects to
        // the error page if it's already been used.
        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.reload();
            }
        });

        async function submitForm(scheduleMeeting) {
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];

            if (!isSystemPhoneVerified) {
                alert(copy.alertVerifyFirst);
                return;
            }

            const sessionToken = document.getElementById('submissionForm').dataset.sessionToken;
            if (!sessionToken) {
                alert(copy.alertSessionMissing);
                return;
            }

            const name = document.getElementById('txtName').value.trim();
            const mobile = document.getElementById('txtMobile').value.trim();
            const description = document.getElementById('txtDesc').value.trim();
            const hasFiles = registeredFileList.filter(f => f !== null).length > 0;
            const hasAudio = document.getElementById('audioRecordingData').value !== '';

            if (!name || !mobile || (!description && !hasFiles && !hasAudio)) {
                showOtpFieldError(copy.alertFillFields);
                return;
            }

            const category = document.getElementById('ddlCategory').value;
            if (!category) {
                alert(copy.alertSelectCategory);
                return;
            }

            // Validate audio recording size (max duration from .env)
            if (hasAudio) {
                const audioData = document.getElementById('audioRecordingData').value;
                // base64 encoding inflates size by ~33%
                // max bytes = seconds * 16 KB * 1.2, encoded ≈ *1.33
                const maxEncodedSize = {{ audio_max_seconds | default(300) }} * 16 * 1024 * 1.2 * 1.33;
                if (audioData.length > maxEncodedSize) {
                    alert(copy.recordingLimit || 'Audio recording exceeds maximum duration. Please re-record.');
                    return;
                }
            }

            // For meeting requests, a slot must be selected UNLESS there are
            // genuinely no slots available (then the request joins the waiting queue).
            const slotId = document.getElementById('selectedSlotId').value;
            if (scheduleMeeting && !slotId && !noSlotsAvailable) {
                showOtpFieldError(copy.slotSelectFirst);
                return;
            }

            const formData = new FormData();
            formData.append('session_token', sessionToken);
            formData.append('name', name);
            formData.append('mobile_number', mobile);
            formData.append('constituency', 'Tamil Nadu');
            formData.append('description', description || 'See attachments or audio');
            formData.append('otp_code', document.getElementById('txtOtp').value);
            formData.append('grievance_category', category);
            formData.append('schedule_meeting', scheduleMeeting.toString());
            if (scheduleMeeting && slotId) {
                formData.append('slot_id', slotId);
                const numPersons = parseInt(document.getElementById('selNumPersons').value) || 1;
                formData.append('num_persons', numPersons.toString());
            }

            const audioData = document.getElementById('audioRecordingData').value;
            formData.append('audio_recording', audioData || '');

            registeredFileList.filter(f => f !== null).forEach(file => {
                formData.append('files', file);
            });

            // Close consent dialog immediately when submission starts
            document.getElementById('consentOverlay').style.display = 'none';

            const btnConfirm   = document.getElementById('btnConfirmMeeting');
            const choiceWrap   = document.getElementById('choiceButtons');
            const choiceHTML   = choiceWrap ? choiceWrap.innerHTML : '';
            const pickerOpen   = document.getElementById('slotPickerSection').style.display !== 'none';

            // Spinner: on the slot-picker's Confirm button when booking a meeting,
            // otherwise replace the inline choice with a "submitting" indicator.
            let spinnerOn = null, spinnerOrig = '';
            if (btnConfirm) btnConfirm.disabled = true;
            if (choiceWrap) choiceWrap.querySelectorAll('button').forEach(b => b.disabled = true);

            if (scheduleMeeting && pickerOpen && btnConfirm) {
                spinnerOn = btnConfirm; spinnerOrig = btnConfirm.innerHTML;
                btnConfirm.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ' + copy.submitting;
            } else if (choiceWrap) {
                choiceWrap.innerHTML = '<div style="text-align:center; padding:1rem; color:#6b7280; font-weight:700;">'
                    + '<i class="fa-solid fa-spinner fa-spin"></i> ' + copy.submitting + '</div>';
            }

            const restoreButtons = () => {
                if (spinnerOn) { spinnerOn.innerHTML = spinnerOrig; spinnerOn.disabled = false; }
                if (choiceWrap) {
                    choiceWrap.innerHTML = choiceHTML;
                    choiceWrap.querySelectorAll('button').forEach(b => b.disabled = false);
                }
                if (btnConfirm) btnConfirm.disabled = false;
            };

            try {
                const response = await fetch('/api/v1/appointments/submit', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const data = await response.json();
                    const params = new URLSearchParams({
                        token: data.token_assigned,
                        name: name,
                        status: data.status || 'SCHEDULED'
                    });
                    if (data.submitted_at) params.set('submitted_at', data.submitted_at);
                    if (data.scheduled_date) params.set('date', data.scheduled_date);
                    if (data.scheduled_time) params.set('time', data.scheduled_time);
                    if (data.scheduled_end)  params.set('time_end', data.scheduled_end);
                    window.location.href = `/form/success?${params.toString()}`;
                } else {
                    const error = await response.json();
                    const errMsg = error.detail || copy.submitError;
                    showOtpFieldError(errMsg);
                    // If slot filled up mid-submit, re-fetch slots so citizen can pick another
                    if (scheduleMeeting && errMsg && errMsg.toLowerCase().includes('slot')) {
                        document.getElementById('selectedSlotId').value = '';
                        document.getElementById('selectedSlotLabel').style.display = 'none';
                        if (btnConfirm) { btnConfirm.disabled = true; }
                        await loadSlots();
                    }
                    restoreButtons();
                }
            } catch (error) {
                showOtpFieldError(copy.networkError);
                restoreButtons();
            }
        }

        // ── Slot picker ────────────────────────────────────────────────────

        let slotRefreshInterval = null;
        let selectedPickerDate  = null;  // YYYY-MM-DD chosen by user
        let slotPickerFirstLoad = true;  // controls the one-time "loading" message
        let noSlotsAvailable    = false; // true when no bookable slot exists → waiting queue

        // Tamil weekday names (0=Sun … 6=Sat)
        const TA_WEEKDAYS = ['ஞாயிறு', 'திங்கள்', 'செவ்வாய்', 'புதன்', 'வியாழன்', 'வெள்ளி', 'சனி'];
        const EN_WEEKDAYS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
        const TA_MONTHS   = ['ஜன', 'பிப்', 'மார்', 'ஏப்', 'மே', 'ஜூன்', 'ஜூலை', 'ஆக', 'செப்', 'அக்', 'நவ', 'டிச'];
        const EN_MONTHS   = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

        // Build date chips ONLY for dates the PA has opened in scheduling.
        // Returns the number of open dates found.
        async function _buildDatePicker() {
            const row = document.getElementById('datePickerRow');
            if (!row) return 0;
            const isTa = runtimeActiveLanguage === 'ta';
            const weekdays = isTa ? TA_WEEKDAYS : EN_WEEKDAYS;
            const months   = isTa ? TA_MONTHS   : EN_MONTHS;

            row.innerHTML = `<div style="font-size:0.78rem;color:#94a3b8;padding:0.4rem;">${dynamicLocalizationDictionary[runtimeActiveLanguage].slotLoading}</div>`;

            // Fetch the dates that are actually open for bookings.
            let openDates = [];
            try {
                const res  = await fetch('/api/v1/scheduling/open-dates');
                const data = await res.json();
                if (Array.isArray(data)) openDates = data;
            } catch (e) { /* network error — handled below */ }

            row.innerHTML = '';
            selectedPickerDate = null;

            if (openDates.length === 0) {
                // No open dates at all — nothing the citizen can book.
                row.innerHTML = `<div style="font-size:0.8rem;color:#b45309;padding:0.4rem;">${dynamicLocalizationDictionary[runtimeActiveLanguage].slotNone}</div>`;
                return 0;
            }

            openDates.forEach((od, idx) => {
                const dateStr = od.date;                 // "YYYY-MM-DD"
                const [yy, mm, dd] = dateStr.split('-').map(Number);
                const d = new Date(yy, mm - 1, dd);      // local midnight
                const dow = d.getDay();

                const chip = document.createElement('div');
                chip.className = 'date-chip' + (idx === 0 ? ' selected' : '');
                chip.dataset.date = dateStr;
                chip.innerHTML = `
                    <div class="dc-weekday">${weekdays[dow]}</div>
                    <div class="dc-day">${d.getDate()}</div>
                    <div class="dc-month">${months[d.getMonth()]}</div>
                `;
                chip.addEventListener('click', function() {
                    document.querySelectorAll('.date-chip').forEach(c => c.classList.remove('selected'));
                    chip.classList.add('selected');
                    selectedPickerDate = dateStr;
                    // Reset slot selection when date changes
                    document.getElementById('selectedSlotId').value = '';
                    document.getElementById('selectedSlotLabel').style.display = 'none';
                    document.getElementById('numPersonsSection').style.display = 'none';
                    document.getElementById('btnConfirmMeeting').disabled = true;
                    slotPickerFirstLoad = true;          // show loading state for new date
                    document.getElementById('slotGrid').innerHTML = '';
                    loadSlots();
                });
                row.appendChild(chip);
                if (idx === 0) selectedPickerDate = dateStr;
            });
            return openDates.length;
        }

        async function openSlotPicker() {
            // One action at a time: hide the inline choice while the slot picker is open
            document.getElementById('actionChoiceInline').style.display = 'none';
            document.getElementById('slotPickerSection').style.display = 'block';
            document.getElementById('selectedSlotId').value = '';
            document.getElementById('selectedSlotLabel').style.display = 'none';
            document.getElementById('numPersonsSection').style.display = 'none';
            document.getElementById('btnConfirmMeeting').disabled = true;
            document.getElementById('slotGrid').innerHTML = '';
            slotPickerFirstLoad = true;
            noSlotsAvailable    = false;

            const numOpenDates = await _buildDatePicker();

            if (numOpenDates === 0) {
                // No open dates — guide citizen to submit into the waiting queue.
                const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
                noSlotsAvailable = true;
                document.getElementById('slotGrid').innerHTML = '';
                document.getElementById('slotPickerMsg').innerHTML =
                    '<span style="color:#b45309;">⚠ ' + copy.slotNone + '</span> ' + copy.slotNoneHint;
                document.getElementById('btnConfirmMeeting').disabled = false;
                document.getElementById('slotPickerSection').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                return;
            }

            await loadSlots();
            // Auto-refresh every 5 s so admin block/close/full changes reflect immediately
            if (slotRefreshInterval) clearInterval(slotRefreshInterval);
            slotRefreshInterval = setInterval(loadSlots, 5000);
            document.getElementById('slotPickerSection').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function closeSlotPicker() {
            document.getElementById('slotPickerSection').style.display = 'none';
            document.getElementById('selectedSlotId').value = '';
            document.getElementById('numPersonsSection').style.display = 'none';
            document.getElementById('selNumPersons').value = '1';
            if (slotRefreshInterval) { clearInterval(slotRefreshInterval); slotRefreshInterval = null; }
            // Bring back the inline choice (Meeting / Petition) when the picker closes
            if (isSystemPhoneVerified) {
                document.getElementById('actionChoiceInline').style.display = 'block';
            }
        }

        async function loadSlots() {
            const msg  = document.getElementById('slotPickerMsg');
            const grid = document.getElementById('slotGrid');
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            const selectedId = document.getElementById('selectedSlotId').value;

            // Only show the "loading" message on the very first load for a date,
            // never on the 5-second background polls (prevents flicker).
            if (slotPickerFirstLoad) {
                msg.textContent = copy.slotLoading;
            }

            const targetDate = selectedPickerDate || (() => {
                const now = new Date();
                return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
            })();

            try {
                const res  = await fetch('/api/v1/scheduling/slots/available?target_date=' + targetDate);
                const data = await res.json();

                // No non-blocked slots exist for this date at all.
                if (!data.slots || data.slots.length === 0) {
                    grid.innerHTML = '';
                    noSlotsAvailable = true;
                    msg.innerHTML = '<span style="color:#b45309;">⚠ ' + copy.slotNone + '</span> ' + copy.slotNoneHint;
                    document.getElementById('btnConfirmMeeting').disabled = false;
                    slotPickerFirstLoad = false;
                    return;
                }

                // Time-of-day comparison for greying past slots (only when date is today).
                const nowLocal   = new Date();
                const nowMinutes = nowLocal.getHours() * 60 + nowLocal.getMinutes();
                const todayStr   = `${nowLocal.getFullYear()}-${String(nowLocal.getMonth() + 1).padStart(2, '0')}-${String(nowLocal.getDate()).padStart(2, '0')}`;
                const isToday    = targetDate === todayStr;

                grid.innerHTML = '';
                let bookableCount = 0;   // counts slots actually selectable (after past-filter)
                let selectionLost = false; // true if the citizen's picked slot just became unavailable

                data.slots.forEach(slot => {
                    const card = document.createElement('div');

                    const [sh, sm]  = slot.start.split(':').map(Number);
                    const slotStart = sh * 60 + sm;
                    const isPast    = isToday && (slotStart <= nowMinutes);

                    // Dynamic state — backend already excludes BLOCKED slots.
                    //   FULL    : remaining === 0 OR status === 'FULL' (admin-closed)  → red, not clickable
                    //   PARTIAL : 0 < booked < max AND bookable                        → amber, clickable
                    //   OPEN    : booked === 0 AND bookable                            → green, clickable
                    const isFull    = !isPast && (slot.remaining === 0 || slot.status === 'FULL');
                    const isPartial = !isPast && !isFull && slot.available && slot.booked_count > 0;
                    const isOpen    = !isPast && !isFull && slot.available && slot.booked_count === 0;
                    const isBookable = isPartial || isOpen;
                    if (isBookable) bookableCount++;
                    const isSelected = String(slot.id) === String(selectedId);

                    let stateClass, pillText;
                    if (isPast)         { stateClass = 'slot-card--past';    pillText = copy.slotPassed; }
                    else if (isFull)    { stateClass = 'slot-card--full';    pillText = copy.slotFull; }
                    else if (isPartial) { stateClass = 'slot-card--partial'; pillText = slot.remaining + ' ' + copy.slotLeft; }
                    else                { stateClass = 'slot-card--open';    pillText = copy.slotAvailable; }

                    const selectedCls = (isSelected && isBookable) ? ' slot-card--selected' : '';
                    card.className = 'slot-card ' + stateClass + selectedCls;
                    card.innerHTML =
                        `<div class="slot-card__time">${slot.start} – ${slot.end}</div>` +
                        `<span class="slot-card__pill">${pillText}</span>`;

                    if (isBookable) {
                        card.addEventListener('click', () => selectSlot(slot.id, slot.label, card));
                    } else if (isSelected) {
                        // The slot the citizen had selected just became full/passed during polling.
                        selectionLost = true;
                        document.getElementById('selectedSlotId').value = '';
                        document.getElementById('selectedSlotLabel').style.display = 'none';
                        document.getElementById('numPersonsSection').style.display = 'none';
                        document.getElementById('btnConfirmMeeting').disabled = true;
                        msg.innerHTML = '<span style="color:#dc2626;">⚠ ' +
                            (isPast ? copy.slotSelectedPast : copy.slotSelectedGone) + '</span>';
                    }
                    grid.appendChild(card);
                });

                // Decide final availability state from what is actually bookable now
                // (accounts for today's past slots that the backend can't know about).
                if (bookableCount > 0) {
                    noSlotsAvailable = false;
                    if (!selectionLost) msg.textContent = copy.slotHint;
                } else {
                    noSlotsAvailable = true;
                    document.getElementById('btnConfirmMeeting').disabled = false;
                    if (!selectionLost) {
                        msg.innerHTML = '<span style="color:#b45309;">⚠ ' + copy.slotAllFull + '</span> ' + copy.slotNoneHint;
                    }
                }

                slotPickerFirstLoad = false;

            } catch (e) {
                if (slotPickerFirstLoad) {
                    msg.textContent = copy.slotFail;
                    document.getElementById('btnConfirmMeeting').disabled = false;
                    slotPickerFirstLoad = false;
                }
            }
        }

        function selectSlot(slotId, label, cardEl) {
            document.querySelectorAll('#slotGrid .slot-card').forEach(c => {
                c.classList.remove('slot-card--selected');
            });
            cardEl.classList.add('slot-card--selected');

            document.getElementById('selectedSlotId').value          = slotId;
            document.getElementById('selectedSlotText').textContent   = label;
            document.getElementById('selectedSlotLabel').style.display = 'block';
            document.getElementById('numPersonsSection').style.display = 'block';
            document.getElementById('selNumPersons').value             = '1';
            document.getElementById('btnConfirmMeeting').disabled     = false;
        }

        // ── Inline action choice (Meeting / Petition / Waitlist) ────────────

        let meetingAvailable = null;   // cached availability boolean

        async function revealActionChoice() {
            // Check whether any meeting slot is bookable, then render the choice.
            try {
                const res  = await fetch('/api/v1/scheduling/meeting-availability');
                const data = await res.json();
                meetingAvailable = !!data.available;
            } catch (e) {
                meetingAvailable = true;   // fail-safe: never wrongly hide meetings
            }
            renderChoiceButtons();
            const box = document.getElementById('actionChoiceInline');
            box.style.display = 'block';
            box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function renderChoiceButtons() {
            const ta   = runtimeActiveLanguage === 'ta';
            const wrap = document.getElementById('choiceButtons');
            document.getElementById('lbl-choice-heading').textContent =
                ta ? 'எப்படி தொடர விரும்புகிறீர்கள்?' : 'How would you like to proceed?';

            // Modular card builder (uses CSS component classes — no inline styling)
            const card = (type, primary, emoji, title, sub, onclick) => `
                <button type="button" class="choice-card choice-card--${type}${primary ? ' choice-card--primary' : ''}" onclick="${onclick}">
                    <span class="choice-card__icon">${emoji}</span>
                    <span>
                        <span class="choice-card__title">${title}</span>
                        <span class="choice-card__sub">${sub}</span>
                    </span>
                </button>`;

            const meeting = (primary) => card('meeting', primary, '🤝',
                ta ? 'அமைச்சரை நேரில் சந்திக்க' : 'Meet the Minister in person',
                ta ? 'நேரத்தைத் தேர்ந்தெடுக்கவும்' : 'Book a time slot',
                "document.getElementById('btnMeeting').click()");

            const petition = (primary) => card('petition', primary, '📄',
                ta ? 'மனுவை மட்டும் சமர்ப்பிக்க' : 'Submit petition only',
                ta ? 'சந்திப்பு இல்லை — பதிவு மட்டும்' : 'No meeting — just register it',
                "document.getElementById('btnPetition').click()");

            const waitlist = (primary) => card('waitlist', primary, '⏳',
                ta ? 'காத்திருப்பு பட்டியலில் சேர' : 'Join the waiting list',
                ta ? 'இடம் கிடைத்ததும் தொடர்பு கொள்வோம்' : "We'll contact you when a slot opens",
                "document.getElementById('btnWaitlist').click()");

            // Professional notice shown only when no meeting slots remain
            const fullNotice = `
                <div class="slots-alert">
                    <span class="slots-alert__icon"><i class="fa-solid fa-circle-info"></i></span>
                    <div class="slots-alert__text">
                        ${ta
                            ? '<strong>தற்போது அனைத்து சந்திப்பு நேரங்களும் நிரம்பிவிட்டன.</strong> நீங்கள் உங்கள் மனுவை சமர்ப்பிக்கலாம் அல்லது காத்திருப்பு பட்டியலில் சேரலாம் — இடம் கிடைத்ததும் உங்களைத் தொடர்பு கொள்வோம்.'
                            : "<strong>All meeting slots are currently full.</strong> You can still submit your petition, or join the waiting list — we'll contact you as soon as a slot opens."}
                    </div>
                </div>`;

            // Dynamic: meeting only when slots exist; otherwise notice + waitlist.
            wrap.innerHTML = meetingAvailable
                ? meeting(true) + petition(false)
                : fullNotice + petition(true) + waitlist(false);
        }

        // Waitlist = request a meeting with no slot → backend puts it in the queue.
        // Goes through the same consent step as a meeting.
        function startWaitlist() {
            noSlotsAvailable = true;   // lets submitForm(true) proceed without a slot
            openConsentDialog();
        }

        // ── Consent dialog ─────────────────────────────────────────────────

        function openConsentDialog() {
            const isTamil   = runtimeActiveLanguage === 'ta';
            const overlay   = document.getElementById('consentOverlay');

            // Show the right language
            document.querySelectorAll('.consent-en').forEach(el => el.style.display = isTamil ? 'none' : '');
            document.querySelectorAll('.consent-ta').forEach(el => el.style.display = isTamil ? '' : 'none');

            // Reset checkbox + confirm button on every open
            document.getElementById('consentCheck').checked     = false;
            document.getElementById('btnConsentConfirm').disabled = true;
            document.getElementById('btnConsentConfirm').style.opacity = '0.45';

            overlay.style.display = 'flex';
        }

        function closeConsentDialog() {
            document.getElementById('consentOverlay').style.display = 'none';
        }

        function onConsentChange() {
            const checked = document.getElementById('consentCheck').checked;
            const btn     = document.getElementById('btnConsentConfirm');
            btn.disabled  = !checked;
            btn.style.opacity = checked ? '1' : '0.45';
        }

        // Audio recording — module-level variables
        let mediaRecorder;
        let audioChunks    = [];
        let recordingStartTime;
        let timerInterval;
        let currentAudioMime = '';
        let activeStream   = null;   // kept here so stopRecording() can stop tracks
        let audioContext    = null;
        let analyser        = null;
        let waveformRAF     = null;   // requestAnimationFrame ID for waveform drawing

        function _resetRecordingUI() {
            const btn   = document.getElementById('btnStartRecording');
            const label = document.getElementById('lbl-record');
            const copy  = dynamicLocalizationDictionary[runtimeActiveLanguage];
            btn.classList.remove('recording');
            btn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
            btn.onclick = startRecording;
            label.textContent = copy.record;
            label.style.color = '#374151';
            document.getElementById('micWaveRing').classList.remove('animate');
            document.getElementById('micWaveRing2').classList.remove('animate');
            _stopWaveform();
            _drawFlatLine();
            document.getElementById('recordingTimer').style.display    = 'none';
            document.getElementById('recordingTimer').textContent      = '0:00';
            document.getElementById('recordingTimer').style.color      = '';
        }

        function _stopActiveTracks() {
            if (activeStream) {
                activeStream.getTracks().forEach(t => t.stop());
                activeStream = null;
            }
        }

        // ── Waveform drawing ─────────────────────────────────────────────

        function _drawFlatLine() {
            const canvas = document.getElementById('waveformCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const dpr = window.devicePixelRatio || 1;
            const rect = canvas.getBoundingClientRect();
            canvas.width  = rect.width * dpr;
            canvas.height = rect.height * dpr;
            ctx.scale(dpr, dpr);
            const w = rect.width;
            const h = rect.height;
            const midY = h / 2;
            ctx.clearRect(0, 0, w, h);
            ctx.strokeStyle = '#cbd5e1';
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.beginPath();
            ctx.moveTo(0, midY);
            ctx.lineTo(w, midY);
            ctx.stroke();
        }

        function _startWaveform(stream) {
            const canvas = document.getElementById('waveformCanvas');
            if (!canvas) return;
            const ctx    = canvas.getContext('2d');
            const dpr    = window.devicePixelRatio || 1;

            function resize() {
                const rect = canvas.getBoundingClientRect();
                canvas.width  = rect.width * dpr;
                canvas.height = rect.height * dpr;
                ctx.scale(dpr, dpr);
            }
            resize();

            // Web Audio API — analyse mic input amplitude
            try {
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const source = audioContext.createMediaStreamSource(stream);
                analyser     = audioContext.createAnalyser();
                analyser.fftSize = 256;
                source.connect(analyser);
            } catch (e) {
                console.warn('[Waveform] Web Audio API not available, drawing static wave.', e);
            }

            const bufferLength = analyser ? analyser.frequencyBinCount : 0;
            const dataArray    = analyser ? new Uint8Array(bufferLength) : null;

            function draw() {
                waveformRAF = requestAnimationFrame(draw);
                const rect = canvas.getBoundingClientRect();
                const w = rect.width;
                const h = rect.height;
                const midY = h / 2;

                ctx.clearRect(0, 0, w, h);

                // Get amplitude from mic input
                let amplitude = 0;
                if (analyser && dataArray) {
                    analyser.getByteTimeDomainData(dataArray);
                    // Calculate RMS amplitude (0–1 scale)
                    let sum = 0;
                    for (let i = 0; i < bufferLength; i++) {
                        const v = (dataArray[i] - 128) / 128;
                        sum += v * v;
                    }
                    amplitude = Math.sqrt(sum / bufferLength);
                }

                // Map amplitude (0–~0.3 typical speech) to pixel height
                const maxBarHeight = h * 0.8;
                const barHeight    = Math.min(amplitude * maxBarHeight * 3, maxBarHeight);

                // Draw centered vertical bar waveform
                const numBars = 48;
                const barWidth = w / numBars;
                const barGap   = barWidth * 0.3;
                const actualBarW = barWidth - barGap;

                for (let i = 0; i < numBars; i++) {
                    // Create a slight wave pattern modulated by amplitude
                    const phase    = (Date.now() / 200 + i * 0.5);
                    const wave     = Math.sin(phase) * 0.3 + 0.7;  // 0.4–1.0
                    const barH     = barHeight * wave;
                    const x        = i * barWidth + barGap / 2;
                    const yTop     = midY - barH / 2;

                    // Color: louder = more red, quieter = lighter
                    const intensity = Math.min(amplitude * 4, 1);
                    const r = 239;
                    const g = Math.round(68 + (1 - intensity) * 120);
                    const b = Math.round(68 + (1 - intensity) * 120);
                    ctx.fillStyle = `rgb(${r},${g},${b})`;
                    ctx.fillRect(x, yTop, actualBarW, barH);
                }
            }
            draw();
        }

        function _stopWaveform() {
            if (waveformRAF) {
                cancelAnimationFrame(waveformRAF);
                waveformRAF = null;
            }
            if (audioContext) {
                try { audioContext.close(); } catch(e) {}
                audioContext = null;
                analyser     = null;
            }
        }

        async function startRecording() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                activeStream  = stream;   // save at module level
                audioChunks   = [];
                currentAudioMime = '';

                // Do NOT pass a mimeType option — each browser uses its native format:
                //   iOS Safari   → audio/mp4  (readable natively on iPhone)
                //   Chrome/Android → audio/webm (readable natively on Android)
                // Passing a forced codec string breaks iOS Safari's recorder.
                mediaRecorder = new MediaRecorder(stream);

                // Capture the actual MIME type the recorder chose
                mediaRecorder.onstart = () => {
                    currentAudioMime = mediaRecorder.mimeType || '';
                };

                mediaRecorder.ondataavailable = (event) => {
                    if (event.data && event.data.size > 0) {
                        audioChunks.push(event.data);
                    }
                };

                mediaRecorder.onstop = () => {
                    // iOS Safari: ondataavailable may arrive slightly after onstop.
                    // A 150 ms delay ensures the last chunk lands before we build the blob.
                    setTimeout(() => {
                        const blobMime = currentAudioMime || 'audio/webm';
                        if (audioChunks.length === 0) {
                            console.warn('[Audio] No data chunks — recording may have failed.');
                            _resetRecordingUI();
                            _stopActiveTracks();
                            return;
                        }
                        const audioBlob = new Blob(audioChunks, { type: blobMime });
                        const audioUrl  = URL.createObjectURL(audioBlob);

                        document.getElementById('audioPlayer').src              = audioUrl;
                        document.getElementById('audioPreview').style.display   = 'block';

                        // Show total recorded duration
                        const totalElapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
                        const totalMin = Math.floor(totalElapsed / 60);
                        const totalSec = totalElapsed % 60;
                        const durEl = document.getElementById('recordingDuration');
                        if (durEl) {
                            durEl.textContent = `${totalMin}:${totalSec.toString().padStart(2, '0')}`;
                        }

                        const reader = new FileReader();
                        reader.readAsDataURL(audioBlob);
                        reader.onloadend = () => {
                            document.getElementById('audioRecordingData').value = reader.result;
                            validateFormForOTP();
                        };

                        // Release mic AFTER blob is ready
                        _stopActiveTracks();
                    }, 150);
                };

                // timeslice = 1000 ms — forces ondataavailable to fire every second.
                // Without this, iOS Safari delivers NO data at all until stop() is called,
                // and then the timing between ondataavailable and onstop is unreliable.
                mediaRecorder.start(1000);
                recordingStartTime = Date.now();

                // Toggle button to recording state
                const btn   = document.getElementById('btnStartRecording');
                const label = document.getElementById('lbl-record');
                const copy  = dynamicLocalizationDictionary[runtimeActiveLanguage];
                btn.classList.add('recording');
                btn.innerHTML = '<i class="fa-solid fa-stop"></i>';
                btn.onclick = stopRecording;
                label.textContent = copy.stop;
                label.style.color = '#ef4444';
                document.getElementById('micWaveRing').classList.add('animate');
                document.getElementById('micWaveRing2').classList.add('animate');
                _startWaveform(stream);
                document.getElementById('recordingTimer').style.display = 'block';

                timerInterval = setInterval(updateTimer, 1000);

            } catch (error) {
                alert(dynamicLocalizationDictionary[runtimeActiveLanguage].micError);
                console.error('Error accessing microphone:', error);
            }
        }

        function stopRecording() {
            if (!mediaRecorder || mediaRecorder.state === 'inactive') return;

            clearInterval(timerInterval);

            // Update timer to show final recorded time before resetting
            const elapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
            const minutes = Math.floor(elapsed / 60);
            const seconds = elapsed % 60;
            const timerEl = document.getElementById('recordingTimer');
            timerEl.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;

            // Stop mic pulse + waveform immediately, but keep timer visible
            const btn = document.getElementById('btnStartRecording');
            btn.classList.remove('recording');
            document.getElementById('micWaveRing').classList.remove('animate');
            document.getElementById('micWaveRing2').classList.remove('animate');
            _stopWaveform();
            _drawFlatLine();

            // Normal stop — onstop handler will build blob and show preview
            mediaRecorder.stop();
            // Reset the button + label, but DON'T hide the timer yet —
            // it stays visible until the audio preview replaces it.
            const label = document.getElementById('lbl-record');
            const copy  = dynamicLocalizationDictionary[runtimeActiveLanguage];
            btn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
            btn.onclick = startRecording;
            label.textContent = copy.record;
            label.style.color = '#374151';
        }

        const MAX_RECORDING_SECONDS = {{ audio_max_seconds | default(300) }}; // configurable via .env

        function updateTimer() {
            const elapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
            const minutes = Math.floor(elapsed / 60);
            const seconds = elapsed % 60;
            const timerEl = document.getElementById('recordingTimer');
            timerEl.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;

            // Turn red in last 30 seconds
            if (elapsed >= MAX_RECORDING_SECONDS - 30) {
                timerEl.style.color = '#dc2626';
            }

            if (elapsed >= MAX_RECORDING_SECONDS) {
                stopRecording();
                timerEl.style.color = '';
                alert(dynamicLocalizationDictionary[runtimeActiveLanguage].recordingLimit || 'Recording stopped at 5 minutes maximum.');
            }
        }

        function deleteRecording() {
            document.getElementById('audioPreview').style.display = 'none';
            document.getElementById('audioRecordingData').value = '';
            document.getElementById('audioPlayer').src = '';
            document.getElementById('recordingTimer').style.display = 'none';
            document.getElementById('recordingTimer').textContent = '0:00';
            document.getElementById('recordingTimer').style.color = '';
            // Trigger validation to update OTP button state
            validateFormForOTP();
        }

        function dismissModalScreen() {
            document.getElementById('successModal').classList.remove('active');
            document.getElementById('submissionForm').reset();
            document.getElementById('filePreviews').innerHTML = "";
            registeredFileList = [];
            
            // Reset audio recording
            deleteRecording();
            
            // Soft reset OTP verification state
            isSystemPhoneVerified = false;
            document.getElementById('otpVerificationWrapper').style.display = 'none';
            document.getElementById('txtMobile').disabled = false;

            document.querySelectorAll('.otp-box').forEach(b => {
                b.value = '';
                b.disabled = false;
                b.classList.remove('otp-valid', 'otp-invalid');
            });
            document.getElementById('txtOtp').value = '';
            clearOtpState();

            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            const genBtn = document.getElementById('btnGenOtp');
            genBtn.innerHTML = '<span id="lbl-send-otp">' + copy.sendOtp + '</span>';
            genBtn.disabled = false;

            const verifyBtn = document.getElementById('btnVerifyOtp');
            verifyBtn.innerHTML = '<span id="lbl-verify-otp">' + copy.verifyOtp + '</span>';
            verifyBtn.disabled = false;
            
            document.getElementById('btnSubmitPetition').disabled = true;
            document.getElementById('btnSubmitMeeting').disabled = true;
        }

        // Apply saved language preference (or default Tamil).
        // switchLocalization(true) = Tamil, switchLocalization(false) = English.
        (function() {
            let savedLang = 'ta';
            try { savedLang = localStorage.getItem('vpa_lang') || 'ta'; } catch(e) {}
            const isTamil = savedLang === 'ta';
            switchLocalization(isTamil);   // also sets the active pill
            _drawFlatLine();
        })();
    </script>
</body>
</html>