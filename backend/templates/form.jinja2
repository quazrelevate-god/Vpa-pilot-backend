                networkError: "இணைய பிழை. மீண்டும் முயற்சிக்கவும்.",
                micError: "மைக்ரோஃபோன் அனுமதி மறுக்கப்பட்டது. தயவுசெய்து அனுமதியை வழங்கவும்.",
                alertFillFields: "OTP கோருவதற்கு முன் பெயர், அலைபேசி எண் மற்றும் விவரம் அல்லது ஆவணம் உள்ளிடவும்.",
                alertVerifyFirst: "சமர்ப்பிக்கும் முன் OTP சரிபார்க்கவும்.",
                alertSessionMissing: "அமர்வு குறியீடு இல்லை. QR குறியீட்டை மீண்டும் ஸ்கேன் செய்யவும்.",
                submitError: "சமர்ப்பிப்பு தோல்வியடைந்தது. மீண்டும் முயற்சிக்கவும்."
            }
        };

        // Null-safe text setter — silently skips missing elements so one
        // absent id never kills the rest of the localization pass.
        function _setText(id, text) {
            const el = document.getElementById(id);
            if (el) el.innerText = text;
        }
        function _setAttr(id, attr, text) {
            const el = document.getElementById(id);
            if (el) el[attr] = text;
        }

        function switchLocalization(isChecked) {
            runtimeActiveLanguage = isChecked ? 'ta' : 'en';
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];

            // Header & section titles
            _setText('lbl-dist',         copy.dist);
            _setText('lbl-portal-title', copy.portalTitle);
            _setText('lbl-sec-title',    copy.secTitle);

            // Field labels
            _setText('lbl-name',        copy.name);
            _setText('lbl-phone',       copy.phone);
            _setText('lbl-otp',         copy.otp);
            _setText('lbl-desc',        copy.desc);
            _setText('lbl-upload',      copy.upload);
            _setText('lbl-upload-text', copy.uploadText);
            _setText('lbl-upload-hint', copy.uploadHint);

            // Submit buttons
            _setText('lbl-btn-petition', copy.btnPetition);
            _setText('lbl-btn-meeting',  copy.btnMeeting);

            // Recording section
            _setText('lbl-audio',           copy.audio);
            _setText('lbl-audio-hint',      copy.audioHint);
            _setText('lbl-record',          copy.record);
            _setText('lbl-stop',            copy.stop);
            _setText('lbl-recording-saved', copy.recordingSaved);
            _setText('lbl-delete-rec',      copy.deleteRec);

            // OTP action buttons
