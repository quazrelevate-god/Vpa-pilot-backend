        // Null-safe text setter — silently skips missing elements so one
        // absent id never kills the rest of the localization pass.
        function _setText(id, text) {
            const el = document.getElementById(id);
            if (el) el.innerText = text;
        }
        function _setAttr(id, attr, text) {
            const el = document.getElementById(id);
            if (el) el[attr] = text;
        }

        const CATEGORY_KEYS = [
            'action_required', 'proposals', 'transfer_requests', 'pension_requests',
            'school_admission', 'job_requests', 'rti', 'associations_unions',
            'other', 'general', 'greetings',
