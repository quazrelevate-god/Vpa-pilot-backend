        function _to12h(t) {
            var p = t.split(':');
            var h = parseInt(p[0], 10);
            var m = p[1];
            var ampm = h >= 12 ? 'PM' : 'AM';
            h = h % 12 || 12;
            return h + ':' + m + ' ' + ampm;
        }

        async function loadSlots() {
            var grid = document.getElementById('slotGrid');
            var copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            var selectedId = document.getElementById('selectedSlotId').value;

            var targetDate = selectedPickerDate || (function() {
                var now = new Date();
                return now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
            })();

            try {
                var res  = await fetch('/api/v1/scheduling/slots/available?target_date=' + targetDate);
                var data = await res.json();

                if (!data.slots || data.slots.length === 0) {
                    grid.innerHTML = '';
                    noSlotsAvailable = true;
                    document.getElementById('btnConfirmMeeting').disabled = false;
                    slotPickerFirstLoad = false;
                    return;
                }

                var nowLocal   = new Date();
                var nowMinutes = nowLocal.getHours() * 60 + nowLocal.getMinutes();
                var todayStr   = nowLocal.getFullYear() + '-' + String(nowLocal.getMonth() + 1).padStart(2, '0') + '-' + String(nowLocal.getDate()).padStart(2, '0');
                var isToday    = targetDate === todayStr;

                grid.innerHTML = '';
                var bookableCount = 0;

                data.slots.forEach(function(slot) {
                    var card = document.createElement('div');

                    var timeParts = slot.start.split(':').map(Number);
                    var slotStart = timeParts[0] * 60 + timeParts[1];
                    var isPast    = isToday && (slotStart <= nowMinutes);

                    var isFull    = !isPast && (slot.remaining === 0 || slot.status === 'FULL');
                    var isPartial = !isPast && !isFull && slot.available && slot.booked_count > 0;
                    var isOpen    = !isPast && !isFull && slot.available && slot.booked_count === 0;
                    var isBookable = isPartial || isOpen;
                    if (isBookable) bookableCount++;
                    var isSelected = String(slot.id) === String(selectedId);

                    var stateClass, pillText;
                    if (isPast)         { stateClass = 'slot-card--past';    pillText = copy.slotPassed; }
                    else if (isFull)    { stateClass = 'slot-card--full';    pillText = copy.slotFull; }
                    else if (isPartial) { stateClass = 'slot-card--partial'; pillText = slot.remaining + ' ' + copy.slotLeft; }
                    else                { stateClass = 'slot-card--open';    pillText = copy.slotAvailable; }

                    var selectedCls = (isSelected && isBookable) ? ' slot-card--selected' : '';
                    card.className = 'slot-card ' + stateClass + selectedCls;
                    card.innerHTML =
                        '<div class="slot-card__time">' + _to12h(slot.start) + ' - ' + _to12h(slot.end) + '</div>' +
                        '<span class="slot-card__pill">' + pillText + '</span>';

                    if (isBookable) {
                        card.addEventListener('click', function() { selectSlot(slot.id, slot.label, card); });
                    } else if (isSelected) {
                        document.getElementById('selectedSlotId').value = '';
                        _selectedSlotTime = '';
                        document.getElementById('numPersonsSection').style.display = 'none';
                        document.getElementById('btnConfirmMeeting').disabled = true;
                        updateConfirmBtnLabel();
                    }
                    grid.appendChild(card);
                });

                if (bookableCount > 0) {
                    noSlotsAvailable = false;
                } else {
                    noSlotsAvailable = true;
                    document.getElementById('btnConfirmMeeting').disabled = false;
                }

                slotPickerFirstLoad = false;

            } catch (e) {
                if (slotPickerFirstLoad) {
                    document.getElementById('btnConfirmMeeting').disabled = false;
                    slotPickerFirstLoad = false;
                }
            }
        }

        var _selectedSlotTime = '';

        function selectSlot(slotId, label, cardEl) {
            document.querySelectorAll('#slotGrid .slot-card').forEach(c => {
                c.classList.remove('slot-card--selected');
            });
            cardEl.classList.add('slot-card--selected');
            document.getElementById('selectedSlotId').value = slotId;
            document.getElementById('selectedSlotText').textContent = label;
            _selectedSlotTime = cardEl.querySelector('.slot-card__time').textContent;
            document.getElementById('numPersonsSection').style.display = 'block';
            document.getElementById('selNumPersons').value = '1';
            document.getElementById('btnConfirmMeeting').disabled = false;
            updateConfirmBtnLabel();
        }

        function updateConfirmBtnLabel() {
            var btn = document.getElementById('btnConfirmMeetingInner');
            if (!btn) return;
            var slotId = document.getElementById('selectedSlotId').value;
            var copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            var ta = runtimeActiveLanguage === 'ta';

            if (!slotId) {
                btn.innerHTML = '<i class="fa-solid fa-handshake"></i> ' + copy.slotConfirm;
                return;
            }

            var numPersons = parseInt(document.getElementById('selNumPersons').value) || 1;
            var personLabel = numPersons === 1
                ? (ta ? '1 நபர்' : '1 person')
                : (numPersons + (ta ? ' நபர்கள்' : ' persons'));

            btn.innerHTML =
                '<i class="fa-solid fa-handshake"></i> ' +
                (ta ? 'உறுதிசெய்' : 'Confirm') +
                '<span style="margin:0 0.4rem; opacity:0.5;">|</span>' +
                '<i class="fa-regular fa-clock" style="font-size:0.8em;"></i> ' + _selectedSlotTime +
                '<span style="margin:0 0.4rem; opacity:0.5;">|</span>' +
                '<i class="fa-solid fa-user" style="font-size:0.8em;"></i> ' + personLabel;
        }

        // ── Inline action choice ───────────────────────────────────────────
        let meetingAvailable = null;

        async function revealActionChoice() {
            try {
                const res  = await fetch('/api/v1/scheduling/meeting-availability');
                const data = await res.json();
                meetingAvailable = !!data.available;
            } catch (e) {
                meetingAvailable = true;
            }
            renderChoiceButtons();
            var box = document.getElementById('actionChoiceInline');
            box.style.display = 'block';
            box.classList.add('revealed');
            _smoothScrollTo(box);
        }

        function renderChoiceButtons() {
            const ta   = runtimeActiveLanguage === 'ta';
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            const wrap = document.getElementById('choiceButtons');

            function card(type, primary, emoji, title, sub, onclick) {
                return '<button type="button" class="choice-card choice-card--' + type + (primary ? ' choice-card--primary' : '') + '" onclick="' + onclick + '">' +
                    '<span class="choice-card__icon">' + emoji + '</span>' +
                    '<span>' +
                        '<span class="choice-card__title">' + title + '</span>' +
                        '<span class="choice-card__sub">' + sub + '</span>' +
                    '</span>' +
                '</button>';
            }

            var meeting = function(primary) {
                return card('meeting', primary, '🤝',
                    ta ? 'அமைச்சரை நேரில் சந்திக்க' : 'Meet the Minister in person',
                    ta ? 'நேரத்தைத் தேர்ந்தெடுக்கவும்' : 'Book a time slot',
                    "document.getElementById('btnMeeting').click()");
            };
            var petition = function(primary) {
                return card('petition', primary, '📄',
                    ta ? 'மனுவை மட்டும் சமர்ப்பிக்க' : 'Submit petition only',
                    ta ? 'சந்திப்பு இல்லை — பதிவு மட்டும்' : 'No meeting - just register it',
                    "document.getElementById('btnPetition').click()");
            };
            var waitlist = function(primary) {
                return card('waitlist', primary, '⌛',
                    ta ? 'காத்திருப்பு பட்டியலில் சேர' : 'Join the waiting list',
                    ta ? 'இடம் கிடைத்ததும் தொடர்பு கொள்வோம்' : "We'll contact you when a slot opens",
                    "document.getElementById('btnWaitlist').click()");
            };

            var fullNotice =
                '<div class="slots-alert">' +
                    '<span class="slots-alert__icon"><i class="fa-solid fa-circle-info"></i></span>' +
                    '<div class="slots-alert__text">' +
                        (ta
                            ? '<strong>தற்போது அனைத்து சந்திப்பு நேரங்களும் நிரம்பிவிட்டன.</strong> நீங்கள் உங்கள் மனுவை சமர்ப்பிக்கலாம் அல்லது காத்திருப்பு பட்டியலில் சேரலாம் — இடம் கிடைத்ததும் உங்களைத் தொடர்பு கொள்வோம்.'
                            : "<strong>All meeting slots are currently full.</strong> You can still submit your petition, or join the waiting list - we'll contact you as soon as a slot opens.") +
                    '</div>' +
                '</div>';

            // Courtesy categories (invitation, greetings) always go through the
            // meeting path so they land in Appointments — never Petition Review.
            // If no slot is available, join the waiting list; there is no
            // "petition only" option for these.
            const courtesy = _isCourtesyCategory();
            if (courtesy) {
                wrap.innerHTML = meetingAvailable ? meeting(true) : fullNotice + waitlist(true);
            } else {
                wrap.innerHTML = meetingAvailable
                    ? meeting(true) + petition(false)
                    : fullNotice + petition(true) + waitlist(false);
            }
        }

        function startWaitlist() {
            noSlotsAvailable = true;
            openConsentDialog();
        }

        // ── Consent dialog ─────────────────────────────────────────────────
        function openConsentDialog() {
            var isTamil   = runtimeActiveLanguage === 'ta';
            var overlay   = document.getElementById('consentOverlay');

            document.querySelectorAll('.consent-en').forEach(function(el) { el.style.display = isTamil ? 'none' : ''; });
            document.querySelectorAll('.consent-ta').forEach(function(el) { el.style.display = isTamil ? '' : 'none'; });

            document.getElementById('consentCheck').checked     = false;
            document.getElementById('btnConsentConfirm').disabled = true;
            document.getElementById('btnConsentConfirm').style.opacity = '0.45';

            overlay.style.display = 'flex';
        }

        function closeConsentDialog() {
            document.getElementById('consentOverlay').style.display = 'none';
        }

        function onConsentChange() {
            var checked = document.getElementById('consentCheck').checked;
            var btn     = document.getElementById('btnConsentConfirm');
            btn.disabled  = !checked;
            btn.style.opacity = checked ? '1' : '0.45';
        }

        // ── Audio recording ────────────────────────────────────────────────
        let mediaRecorder;
        let audioChunks    = [];
        let recordingStartTime;
        let timerInterval;
        let currentAudioMime = '';
        let activeStream   = null;
        let audioContext    = null;
        let analyser        = null;
        let waveformRAF     = null;

        function _resetRecordingUI() {
            var btn   = document.getElementById('btnStartRecording');
            var label = document.getElementById('lbl-record');
            var copy  = dynamicLocalizationDictionary[runtimeActiveLanguage];
            btn.classList.remove('recording');
            btn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
            btn.onclick = startRecording;
            label.textContent = copy.record;
            label.style.color = '#374151';
            document.getElementById('micWaveRing').classList.remove('animate');
            document.getElementById('micWaveRing2').classList.remove('animate');
            _stopWaveform();
            _drawFlatLine();
            document.getElementById('recordingTimer').style.display    = 'none';
            document.getElementById('recordingTimer').textContent      = '0:00';
            document.getElementById('recordingTimer').style.color      = '';
        }

        function _stopActiveTracks() {
            if (activeStream) {
                activeStream.getTracks().forEach(function(t) { t.stop(); });
                activeStream = null;
            }
        }

        function _drawFlatLine() {
            var canvas = document.getElementById('waveformCanvas');
            if (!canvas) return;
            var ctx = canvas.getContext('2d');
            var dpr = window.devicePixelRatio || 1;
            var rect = canvas.getBoundingClientRect();
            canvas.width  = rect.width * dpr;
            canvas.height = rect.height * dpr;
            ctx.scale(dpr, dpr);
            var w = rect.width;
            var h = rect.height;
            var midY = h / 2;
            ctx.clearRect(0, 0, w, h);
            ctx.strokeStyle = '#cbd5e1';
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.beginPath();
            ctx.moveTo(0, midY);
            ctx.lineTo(w, midY);
            ctx.stroke();
        }

        function _startWaveform(stream) {
            var canvas = document.getElementById('waveformCanvas');
            if (!canvas) return;
            var ctx    = canvas.getContext('2d');
            var dpr    = window.devicePixelRatio || 1;

            var rect = canvas.getBoundingClientRect();
            canvas.width  = rect.width * dpr;
            canvas.height = rect.height * dpr;
            ctx.scale(dpr, dpr);

            try {
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                var source = audioContext.createMediaStreamSource(stream);
                analyser     = audioContext.createAnalyser();
                analyser.fftSize = 256;
                source.connect(analyser);
            } catch (e) {
                console.warn('[Waveform] Web Audio API not available.', e);
            }

            var bufferLength = analyser ? analyser.frequencyBinCount : 0;
            var dataArray    = analyser ? new Uint8Array(bufferLength) : null;

            function draw() {
                waveformRAF = requestAnimationFrame(draw);
                var rect2 = canvas.getBoundingClientRect();
                var w = rect2.width;
                var h = rect2.height;
                var midY = h / 2;

                ctx.clearRect(0, 0, w, h);

                var amplitude = 0;
                if (analyser && dataArray) {
                    analyser.getByteTimeDomainData(dataArray);
                    var sum = 0;
                    for (var i = 0; i < bufferLength; i++) {
                        var v = (dataArray[i] - 128) / 128;
                        sum += v * v;
                    }
                    amplitude = Math.sqrt(sum / bufferLength);
                }

                var maxBarHeight = h * 0.8;
                var barHeight    = Math.min(amplitude * maxBarHeight * 3, maxBarHeight);
                var numBars = 48;
                var barWidth = w / numBars;
                var barGap   = barWidth * 0.3;
                var actualBarW = barWidth - barGap;

                for (var j = 0; j < numBars; j++) {
                    var phase    = (Date.now() / 200 + j * 0.5);
                    var wave     = Math.sin(phase) * 0.3 + 0.7;
                    var barH     = barHeight * wave;
                    var x        = j * barWidth + barGap / 2;
                    var yTop     = midY - barH / 2;

                    var intensity = Math.min(amplitude * 4, 1);
                    var r = 239;
                    var g = Math.round(68 + (1 - intensity) * 120);
                    var b = Math.round(68 + (1 - intensity) * 120);
                    ctx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
                    ctx.fillRect(x, yTop, actualBarW, barH);
                }
            }
            draw();
        }

        function _stopWaveform() {
            if (waveformRAF) {
                cancelAnimationFrame(waveformRAF);
                waveformRAF = null;
            }
            if (audioContext) {
                try { audioContext.close(); } catch(e) {}
                audioContext = null;
                analyser     = null;
            }
        }

        async function startRecording() {
            try {
                var stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                activeStream  = stream;
                audioChunks   = [];
                currentAudioMime = '';

                mediaRecorder = new MediaRecorder(stream);

                mediaRecorder.onstart = function() {
                    currentAudioMime = mediaRecorder.mimeType || '';
                };

                mediaRecorder.ondataavailable = function(event) {
                    if (event.data && event.data.size > 0) {
                        audioChunks.push(event.data);
                    }
                };

                mediaRecorder.onstop = function() {
                    setTimeout(function() {
                        var blobMime = currentAudioMime || 'audio/webm';
                        if (audioChunks.length === 0) {
                            console.warn('[Audio] No data chunks.');
                            _resetRecordingUI();
                            _stopActiveTracks();
                            return;
                        }
                        var audioBlob = new Blob(audioChunks, { type: blobMime });
                        var audioUrl  = URL.createObjectURL(audioBlob);

                        document.getElementById('audioPlayer').src              = audioUrl;
                        document.getElementById('audioPreview').style.display   = 'block';

                        var totalElapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
                        var totalMin = Math.floor(totalElapsed / 60);
                        var totalSec = totalElapsed % 60;
                        var durEl = document.getElementById('recordingDuration');
                        if (durEl) {
                            durEl.textContent = totalMin + ':' + totalSec.toString().padStart(2, '0');
                        }

                        var reader = new FileReader();
                        reader.readAsDataURL(audioBlob);
                        reader.onloadend = function() {
                            document.getElementById('audioRecordingData').value = reader.result;
                            validateFormForOTP();
                        };

                        _stopActiveTracks();
                        _smoothScrollTo(document.getElementById('phaseVerify'));
                    }, 150);
                };

                mediaRecorder.start(1000);
                recordingStartTime = Date.now();

                var btn   = document.getElementById('btnStartRecording');
                var label = document.getElementById('lbl-record');
                var copy  = dynamicLocalizationDictionary[runtimeActiveLanguage];
                btn.classList.add('recording');
                btn.innerHTML = '<i class="fa-solid fa-stop"></i>';
                btn.onclick = stopRecording;
                label.textContent = copy.stop;
                label.style.color = '#ef4444';
                document.getElementById('micWaveRing').classList.add('animate');
                document.getElementById('micWaveRing2').classList.add('animate');
                _startWaveform(stream);
                document.getElementById('recordingTimer').style.display = 'block';

                timerInterval = setInterval(updateTimer, 1000);

            } catch (error) {
                alert(dynamicLocalizationDictionary[runtimeActiveLanguage].micError);
                console.error('Error accessing microphone:', error);
            }
        }

        function stopRecording() {
            if (!mediaRecorder || mediaRecorder.state === 'inactive') return;

            clearInterval(timerInterval);

            var elapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
            var minutes = Math.floor(elapsed / 60);
            var seconds = elapsed % 60;
            var timerEl = document.getElementById('recordingTimer');
            timerEl.textContent = minutes + ':' + seconds.toString().padStart(2, '0');

            var btn = document.getElementById('btnStartRecording');
            btn.classList.remove('recording');
            document.getElementById('micWaveRing').classList.remove('animate');
            document.getElementById('micWaveRing2').classList.remove('animate');
            _stopWaveform();
            _drawFlatLine();

            mediaRecorder.stop();
            var label = document.getElementById('lbl-record');
            var copy  = dynamicLocalizationDictionary[runtimeActiveLanguage];
            btn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
            btn.onclick = startRecording;
            label.textContent = copy.record;
            label.style.color = '#374151';
        }

        var MAX_RECORDING_SECONDS = {{ audio_max_seconds | default(300) }};

        function updateTimer() {
            var elapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
            var minutes = Math.floor(elapsed / 60);
            var seconds = elapsed % 60;
            var timerEl = document.getElementById('recordingTimer');
            timerEl.textContent = minutes + ':' + seconds.toString().padStart(2, '0');

            if (elapsed >= MAX_RECORDING_SECONDS - 30) {
                timerEl.style.color = '#dc2626';
            }

            if (elapsed >= MAX_RECORDING_SECONDS) {
                stopRecording();
                timerEl.style.color = '';
                alert(dynamicLocalizationDictionary[runtimeActiveLanguage].recordingLimit || 'Recording stopped at 5 minutes maximum.');
            }
        }

        function deleteRecording() {
            document.getElementById('audioPreview').style.display = 'none';
            document.getElementById('audioRecordingData').value = '';
            document.getElementById('audioPlayer').src = '';
            document.getElementById('recordingTimer').style.display = 'none';
            document.getElementById('recordingTimer').textContent = '0:00';
            document.getElementById('recordingTimer').style.color = '';
            validateFormForOTP();
        }

        function dismissModalScreen() {
            document.getElementById('successModal').classList.remove('active');
            document.getElementById('submissionForm').reset();
            document.getElementById('filePreviews').innerHTML = "";
            registeredFileList = [];
            deleteRecording();
            isSystemPhoneVerified = false;
            document.getElementById('otpVerificationWrapper').style.display = 'none';
            document.getElementById('txtMobile').disabled = false;
            document.querySelectorAll('.otp-box').forEach(function(b) {
                b.value = '';
                b.disabled = false;
                b.classList.remove('otp-valid', 'otp-invalid');
            });
            document.getElementById('txtOtp').value = '';
            clearOtpState();
            var copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            var genBtn = document.getElementById('btnGenOtp');
            genBtn.innerHTML = '<span id="lbl-send-otp">' + copy.sendOtp + '</span>';
            genBtn.disabled = false;
            var verifyBtn = document.getElementById('btnVerifyOtp');
            verifyBtn.innerHTML = '<span id="lbl-verify-otp">' + copy.verifyOtp + '</span>';
            verifyBtn.disabled = false;
            document.getElementById('actionChoiceInline').style.display = 'none';
            document.getElementById('slotPickerSection').style.display = 'none';
            if (slotRefreshInterval) { clearInterval(slotRefreshInterval); slotRefreshInterval = null; }
            updateStepper();
        }

        // Apply saved language preference
        (function() {
            var savedLang = 'ta';
            try { savedLang = localStorage.getItem('vpa_lang') || 'ta'; } catch(e) {}
            var isTamil = savedLang === 'ta';
            switchLocalization(isTamil);
            _drawFlatLine();
        })();
    </script>
</body>
</html>
