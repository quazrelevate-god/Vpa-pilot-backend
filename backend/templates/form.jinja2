                sendOtp: "OTP அனுப்பு", sending: "அனுப்புகிறோம்...", sent: "அனுப்பப்பட்டது ✓",
                verifyOtp: "OTP சரிபார்", verifying: "சரிபார்க்கிறோம்...", verified: "✓ சரிபார்க்கப்பட்டது",
                otpSuccess: "OTP சரிபார்க்கப்பட்டது ✓",
