    <!-- Runtime JavaScript -->
    <script>
        let registeredFileList = [];
        let runtimeActiveLanguage = 'ta';
        let isSystemPhoneVerified = false;

        // ── Stepper tracking ──────────────────────────────────────────────
        function updateStepper() {
            const step1El = document.getElementById('step1');
            const step2El = document.getElementById('step2');
            const step3El = document.getElementById('step3');
            const line1   = document.getElementById('stepLine1');
            const line2   = document.getElementById('stepLine2');

            const detailsDone = isPhase1Complete();
            const verifyDone  = isSystemPhoneVerified;

            step1El.className = detailsDone ? 'step done' : 'step active';
            line1.className   = detailsDone ? 'step-line done' : 'step-line';
            step2El.className = verifyDone ? 'step done' : (detailsDone ? 'step active' : 'step');
            line2.className   = verifyDone ? 'step-line done' : 'step-line';
            step3El.className = verifyDone ? 'step active' : 'step';
        }

        function _smoothScrollTo(el) {
            if (!el) return;
            var lb = document.querySelector('.lang-bar');
            var offset = (lb ? lb.offsetHeight : 48) + 64;
            var top = el.getBoundingClientRect().top + window.pageYOffset - offset;
            window.scrollTo({ top: top, behavior: 'smooth' });
        }

        function isPhase1Complete() {
            const name = document.getElementById('txtName').value.trim();
            const hasCategory = document.getElementById('ddlCategory').value !== '';
            const hasFiles = registeredFileList.filter(f => f !== null).length > 0;
            const hasAudio = document.getElementById('audioRecordingData').value !== '';
            const description = document.getElementById('txtDesc').value.trim();
            return name && hasCategory && (description || hasFiles || hasAudio);
        }

        function validateFormForOTP() {
            const name = document.getElementById('txtName').value.trim();
            const mobile = document.getElementById('txtMobile').value.trim();
            const description = document.getElementById('txtDesc').value.trim();
            const hasFiles = registeredFileList.filter(f => f !== null).length > 0;
            const hasAudio = document.getElementById('audioRecordingData').value !== '';
            const hasCategory = document.getElementById('ddlCategory').value !== '';

            const isValid = name && mobile && hasCategory && (description || hasFiles || hasAudio);
            document.getElementById('btnGenOtp').disabled = !isValid;

            updateStepper();
            return isValid;
        }

