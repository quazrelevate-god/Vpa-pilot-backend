        function _setText(id, text) {
            const el = document.getElementById(id);
            if (el) el.innerText = text;
        }
        function _setAttr(id, attr, text) {
            const el = document.getElementById(id);
            if (el) el[attr] = text;
        }

        const CATEGORY_KEYS = [
            'action_required', 'proposals', 'transfer_requests', 'pension_requests',
            'school_admission', 'job_requests', 'rti', 'associations_unions',
            'other', 'general', 'greetings', 'invitation',
        ];
        const CATEGORY_LABEL_KEYS = {
            action_required: 'catActionRequired', proposals: 'catProposals',
            transfer_requests: 'catTransferRequests', pension_requests: 'catPensionRequests',
            school_admission: 'catSchoolAdmission', job_requests: 'catJobRequests',
            rti: 'catRti', associations_unions: 'catAssociationsUnions',
            other: 'catOther', general: 'catGeneral', greetings: 'catGreetings',
            invitation: 'catInvitation',
        };
        // Courtesy categories skip the petition/AI path — voice message only,
        // and the submission always lands in Appointments (not Petition Review).
        const COURTESY_CATEGORIES = new Set(['invitation', 'greetings']);

        function _populateCategoryDropdown() {
            const ddl = document.getElementById('ddlCategory');
            if (!ddl) return;
            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];
            const prevValue = ddl.value;
            ddl.innerHTML = '';
            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = copy.categorySelect;
            ddl.appendChild(defaultOpt);
            CATEGORY_KEYS.forEach(key => {
                const opt = document.createElement('option');
                opt.value = key;
                opt.textContent = copy[CATEGORY_LABEL_KEYS[key]];
                ddl.appendChild(opt);
            });
            ddl.value = prevValue;
        }

        // Currently-selected category is a courtesy one.
        function _isCourtesyCategory() {
            const ddl = document.getElementById('ddlCategory');
            return !!(ddl && COURTESY_CATEGORIES.has(ddl.value));
        }

        // Hide the file-upload block for invitation/greetings and show a short
        // hint that voice is the only input needed. Any files already picked
        // are cleared so they don't sneak into the submission. Re-runs on
        // language switch too, so the hint stays localised.
        function applyCourtesyModeToUploadSection() {
            const uploadSection = document.getElementById('sectionUpload');
            const noteEl        = document.getElementById('lbl-courtesy-audio-only');
            const copy          = dynamicLocalizationDictionary[runtimeActiveLanguage];
            if (!uploadSection) return;
            const courtesy = _isCourtesyCategory();

            uploadSection.style.display = courtesy ? 'none' : '';
            if (courtesy) {
                // Drop any queued files so the submission carries no attachments.
                if (typeof registeredFileList !== 'undefined' && Array.isArray(registeredFileList)) {
                    registeredFileList.length = 0;
                    const preview = document.getElementById('filePreviews');
                    if (preview) preview.innerHTML = '';
                    const fi = document.getElementById('fileAttachments');
                    if (fi) fi.value = '';
                }
            }
            if (noteEl) {
                noteEl.style.display   = courtesy ? '' : 'none';
                noteEl.textContent     = copy.audioOnlyHint || '';
            }
        }

        function switchLocalization(isChecked) {
            runtimeActiveLanguage = isChecked ? 'ta' : 'en';
            try { localStorage.setItem('vpa_lang', runtimeActiveLanguage); } catch(e) {}

            const enBtn = document.getElementById('langBtnEn');
            const taBtn = document.getElementById('langBtnTa');
            if (enBtn && taBtn) {
                enBtn.classList.toggle('active', !isChecked);
                taBtn.classList.toggle('active', isChecked);
            }

            const copy = dynamicLocalizationDictionary[runtimeActiveLanguage];

            _setText('lbl-portal-title', copy.portalTitle);
            _setText('lbl-sec-title',    copy.secTitle);
            _setText('lbl-phase-verify', copy.phaseVerify);
            _setText('stepLabel1', copy.stepDetails);
            _setText('stepLabel2', copy.stepVerify);
            _setText('stepLabel3', copy.stepSubmit);
            _setText('lbl-name',        copy.name);
            _setText('lbl-phone',       copy.phone);
            _setText('lbl-otp',         copy.otp);
            _setText('lbl-desc',        copy.desc);
            _setText('lbl-upload',      copy.upload);
            _setText('lbl-upload-text', copy.uploadText);
            _setText('lbl-upload-hint', copy.uploadHint);
            _setText('lbl-category', copy.category);
            _populateCategoryDropdown();
            applyCourtesyModeToUploadSection();
            _setText('lbl-slot-title',   copy.slotTitle);
            _setText('lbl-slot-confirm', copy.slotConfirm);
            _setText('lbl-slot-date',    copy.slotSelectDate);
            _setText('lbl-num-persons', copy.numPersonsLabel);
            _setText('opt-persons-1',   copy.optPersons1);
            _setText('opt-persons-2',   copy.optPersons2);
            _setText('opt-persons-3',   copy.optPersons3);
            _setText('opt-persons-4',   copy.optPersons4);
            if (document.getElementById('slotPickerSection').style.display !== 'none') {
                _relabelDateChips();
            }
            _setText('lbl-audio',           copy.audio);
            _setText('lbl-audio-hint',      copy.audioHint);
            const micBtn = document.getElementById('btnStartRecording');
            if (!micBtn || !micBtn.classList.contains('recording')) {
                _setText('lbl-record', copy.record);
            } else {
                _setText('lbl-record', copy.stop);
            }
