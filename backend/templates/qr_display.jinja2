<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code - Tamil Nadu Government</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Mukta+Malar:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', 'Mukta Malar', sans-serif;
            background: #ffffff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            overflow: hidden;
        }

        .container {
            position: relative;
            width: 100%;
            max-width: 1200px;
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(40px) saturate(200%);
            -webkit-backdrop-filter: blur(40px) saturate(200%);
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15), inset 0 1px 1px rgba(255, 255, 255, 1);
            padding: 2rem;
            text-align: center;
        }
        
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 2rem;
            align-items: center;
            margin-top: 2rem;
            max-width: 1000px;
            margin-left: auto;
            margin-right: auto;
        }

        .header {
            margin-bottom: 2rem;
            text-align: center;
        }

        .title-en {
            color: #1f2937;
            font-size: 1.75rem;
            font-weight: 800;
            margin-bottom: 0.25rem;
        }

        .title-ta {
            color: #1f2937;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .subtitle-en {
            color: #6b7280;
            font-size: 0.95rem;
            margin-bottom: 0.25rem;
        }

        .subtitle-ta {
            color: #6b7280;
            font-size: 0.9rem;
        }


        #qrcode {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 500px;
        }

        .timer-container {
            background: rgba(59, 130, 246, 0.1);
            border: 2px solid #3b82f6;
            padding: 2rem;
            border-radius: 16px;
            text-align: center;
        }

        .timer-label-en {
            color: #1e40af;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .timer-label-ta {
            color: #1e40af;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
        }

        .timer-display {
            font-size: 3rem;
            font-weight: 900;
            color: #1f2937;
            font-variant-numeric: tabular-nums;
        }

        .timer-display.warning {
            color: #f59e0b;
        }

        .timer-display.danger {
            color: #ef4444;
        }

        .instructions {
            background: rgba(16, 185, 129, 0.1);
            border: 2px solid #10b981;
            padding: 1.5rem;
            border-radius: 16px;
            text-align: left;
        }

        .instructions h3 {
            color: #065f46;
            font-size: 0.95rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .instructions ul {
            list-style: none;
            padding: 0;
            color: #4b5563;
            font-size: 0.85rem;
            line-height: 1.8;
        }

        .instructions li {
            margin-bottom: 0.75rem;
            padding-left: 1.5rem;
            position: relative;
        }

        .instructions li:before {
            content: "✓";
            position: absolute;
            left: 0;
            color: #10b981;
            font-weight: bold;
        }

        .footer-text {
            color: #6b7280;
            font-size: 0.85rem;
            margin-top: 2rem;
        }

        .loading {
            color: #6b7280;
            font-size: 1rem;
        }

        .refresh-message {
            background: rgba(245, 158, 11, 0.1);
            border: 1px solid rgba(245, 158, 11, 0.3);
            padding: 1rem;
            border-radius: 8px;
            margin-top: 1rem;
            display: none;
        }

        .refresh-message.show {
            display: block;
        }

        .refresh-text-en {
            color: #92400e;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 0.25rem;
        }

        .refresh-text-ta {
            color: #92400e;
            font-weight: 600;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="content-grid">

            <!-- Center: QR Code -->
            <div class="qr-container">
                <div id="qrcode">
                    <div id="qr-loading" class="loading">Generating...</div>
                </div>
            </div>

            <!-- Right: Timer -->
            <div class="timer-container">
                <div class="timer-label-en">Valid for</div>
                <div class="timer-label-ta">செல்லுபடியாகும்</div>
                <div class="timer-display" id="timer">60</div>
                <div style="color: #6b7280; font-size: 0.85rem; margin-top: 0.5rem;">
                    seconds<br>விநாடிகள்
                </div>
                <div class="refresh-message" id="refreshMessage" style="margin-top: 1rem;">
                    <div class="refresh-text-en">Refreshing...</div>
                    <div class="refresh-text-ta">புதுப்பிக்கப்படுகிறது...</div>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        const EXPIRY = {{ expiry_seconds }};
        let countdown = EXPIRY;

        // Clear "Generating..." placeholder, then render QR
        const qrContainer = document.getElementById('qrcode');
        qrContainer.innerHTML = '';
        new QRCode(qrContainer, {
            text: '{{ qr_url }}',
            width: 500,
            height: 500,
            colorDark: '#000000',
            colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.H
        });

        // Hide the "Generating..." placeholder once the QR image appears
        const loadingEl = document.getElementById('qr-loading');
        const observer = new MutationObserver(() => {
            if (qrContainer.querySelector('img, canvas')) {
                loadingEl.style.display = 'none';
                observer.disconnect();
            }
        });
        observer.observe(qrContainer, { childList: true, subtree: true });

        // Countdown timer
        const timerEl = document.getElementById('timer');
        const refreshMsg = document.getElementById('refreshMessage');

        function updateTimerColor() {
            // Calculate color from green (100%) to red (0%)
            const percentage = (countdown / EXPIRY) * 100;
            let color;
            
            if (percentage > 66) {
                // Green zone (100% - 66%)
                color = '#10b981'; // green
            } else if (percentage > 33) {
                // Yellow/Orange zone (66% - 33%)
                color = '#f59e0b'; // orange
            } else if (percentage > 0) {
                // Red zone (33% - 0%)
                color = '#ef4444'; // red
            } else {
                // Expired
                color = '#dc2626'; // dark red
            }
            
            timerEl.style.color = color;
        }

        setInterval(() => {
            if (countdown > 0) {
                countdown--;
                timerEl.textContent = countdown;
                updateTimerColor();
                
                if (countdown <= 5) refreshMsg.classList.add('show');
                
                if (countdown === 0) {
                    setTimeout(() => window.location.reload(), 1000);
                }
            }
        }, 1000);
        
        // Initial color
        updateTimerColor();
    </script>
</body>
</html>
