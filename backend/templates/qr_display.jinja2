<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code - Grievance Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Mukta+Malar:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', 'Mukta Malar', sans-serif;
            /* Soft cool-white gradient — gives the glass card something real to blur against */
            background: linear-gradient(145deg, #e8f0fe 0%, #f0f7ff 50%, #e8f4fd 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        /* ── Full-width refresh banner (slides in from top) ─────────────────── */
        .refresh-banner {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: linear-gradient(90deg, #d97706, #f59e0b, #d97706);
            color: #1c1917;
            text-align: center;
            padding: 0.9rem 1.5rem;
            font-size: clamp(0.95rem, 1.6vw, 1.15rem);
            font-weight: 700;
            letter-spacing: 0.01em;
            z-index: 100;
            transform: translateY(-100%);
            transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .refresh-banner.show {
            transform: translateY(0);
        }

        /* ── Error overlay ──────────────────────────────────────────────────── */
        .error-overlay {
            position: fixed;
            inset: 0;
            background: rgba(241, 245, 249, 0.92);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 200;
        }
        .error-overlay.show {
            display: flex;
        }
        .error-card {
            background: #ffffff;
            border: 2px solid rgba(239, 68, 68, 0.35);
            border-radius: 24px;
            padding: 3rem 3.5rem;
            text-align: center;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10);
        }
        .error-icon {
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            margin-bottom: 1.25rem;
        }
        .error-title-en {
            color: #b91c1c;
            font-size: clamp(1.2rem, 2vw, 1.6rem);
            font-weight: 800;
        }
        .error-title-ta {
            color: #dc2626;
            font-size: clamp(0.95rem, 1.6vw, 1.25rem);
            font-weight: 700;
            margin-top: 0.2rem;
            opacity: 0.8;
        }
        .error-hint {
            color: #6b7280;
            font-size: clamp(0.8rem, 1.2vw, 0.95rem);
            margin-top: 1rem;
            line-height: 1.6;
        }
        .retry-label {
            display: inline-block;
            margin-top: 1.5rem;
            background: #fef3c7;
            border: 1px solid #fcd34d;
            color: #92400e;
            font-size: clamp(0.85rem, 1.3vw, 1rem);
            font-weight: 700;
            padding: 0.55rem 1.25rem;
            border-radius: 50px;
        }

        /* ── Main container ─────────────────────────────────────────────────── */
        .container {
            width: 100%;
            max-width: 1200px;
            /* Now that body has a gradient, the glass blur is meaningful */
            background: rgba(255, 255, 255, 0.72);
            backdrop-filter: blur(24px) saturate(180%);
            -webkit-backdrop-filter: blur(24px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 28px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08), inset 0 1px 1px rgba(255, 255, 255, 1);
            padding: 2.5rem 2rem 2rem;
            text-align: center;
        }

        /* ── Header ─────────────────────────────────────────────────────────── */
        .header {
            margin-bottom: 2.5rem;
        }
        .title-en {
            color: #1f2937;
            font-size: clamp(2rem, 3.5vw, 3.2rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            line-height: 1.1;
        }
        .title-ta {
            color: #374151;
            font-size: clamp(1.3rem, 2.4vw, 2.2rem);
            font-weight: 700;
            margin-top: 0.3rem;
            line-height: 1.2;
        }
        .subtitle {
            color: #6b7280;
            font-size: clamp(0.82rem, 1.25vw, 1rem);
            margin-top: 0.85rem;
            line-height: 1.7;
        }

        /* ── Three-column content grid ──────────────────────────────────────── */
        .content-grid {
            display: grid;
            grid-template-columns: minmax(190px, 260px) 1fr minmax(190px, 260px);
            gap: 2rem;
            align-items: center;
            max-width: 1050px;
            margin: 0 auto;
        }

        /* ── Instructions (left) ────────────────────────────────────────────── */
        .instructions {
            background: rgba(16, 185, 129, 0.07);
            border: 2px solid rgba(16, 185, 129, 0.35);
            padding: 1.5rem 1.25rem;
            border-radius: 18px;
            text-align: left;
            align-self: center;
        }
        .instr-head-en {
            color: #065f46;
            font-size: clamp(1rem, 1.6vw, 1.2rem);
            font-weight: 800;
        }
        .instr-head-ta {
            color: #047857;
            font-size: clamp(0.82rem, 1.2vw, 0.98rem);
            font-weight: 600;
            margin-top: 0.1rem;
            margin-bottom: 1.1rem;
            opacity: 0.8;
        }
        .instructions ul {
            list-style: none;
            padding: 0;
            counter-reset: step;
        }
        .instructions li {
            counter-increment: step;
            position: relative;
            padding: 0.65rem 0 0.65rem 2.1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
        .instructions li:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }
        .instructions li::before {
            content: counter(step);
            position: absolute;
            left: 0;
            top: 0.7rem;
            width: 22px;
            height: 22px;
            background: #10b981;
            color: #fff;
            border-radius: 50%;
            font-size: 0.68rem;
            font-weight: 800;
            text-align: center;
            line-height: 22px;
        }
        .step-en {
            display: block;
            color: #1f2937;
            font-size: clamp(0.82rem, 1.3vw, 1rem);
            font-weight: 600;
        }
        .step-ta {
            display: block;
            color: #6b7280;
            font-size: clamp(0.7rem, 1.05vw, 0.85rem);
            margin-top: 0.1rem;
        }

        /* ── QR card (center) ───────────────────────────────────────────────── */
        .qr-center {
            display: flex;
            justify-content: center;
        }
        .qr-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow:
                0 4px 6px rgba(0, 0, 0, 0.05),
                0 10px 40px rgba(0, 0, 0, 0.12);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            animation: qr-glow 3s ease-in-out infinite;
        }
        @keyframes qr-glow {
            0%, 100% { box-shadow: 0 4px 6px rgba(0,0,0,0.05), 0 10px 40px rgba(0,0,0,0.12); }
            50%       { box-shadow: 0 4px 6px rgba(0,0,0,0.05), 0 10px 48px rgba(59,130,246,0.18); }
        }
        #qrcode {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 440px;
            height: 440px;
        }
        .qr-loading {
            color: #9ca3af;
            font-size: 1rem;
        }

        /* ── Timer with SVG ring (right) ────────────────────────────────────── */
        .timer-container {
            background: rgba(59, 130, 246, 0.07);
            border: 2px solid rgba(59, 130, 246, 0.28);
            padding: 1.75rem 1.25rem;
            border-radius: 18px;
            text-align: center;
            align-self: center;
        }
        .timer-label-en {
            color: #1e40af;
            font-size: clamp(0.85rem, 1.3vw, 1rem);
            font-weight: 700;
        }
        .timer-label-ta {
            color: #1d4ed8;
            font-size: clamp(0.72rem, 1.1vw, 0.88rem);
            font-weight: 600;
            margin-top: 0.1rem;
            margin-bottom: 1.1rem;
            opacity: 0.75;
        }

        /* SVG ring wrapping the countdown number */
        .timer-ring-wrap {
            position: relative;
            width: 140px;
            height: 140px;
            margin: 0 auto;
        }
        .timer-ring {
            width: 140px;
            height: 140px;
            transform: rotate(-90deg);
        }
        .ring-bg {
            fill: none;
            stroke: #e2e8f0;
            stroke-width: 9;
        }
        .ring-progress {
            fill: none;
            stroke: #10b981;
            stroke-width: 9;
            stroke-linecap: round;
            /* circumference = 2π × 54 ≈ 339.29 */
            stroke-dasharray: 339.29;
            stroke-dashoffset: 0;
            transition: stroke-dashoffset 0.9s linear, stroke 0.5s ease;
        }
        .timer-number {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: clamp(2.2rem, 3.5vw, 3rem);
            font-weight: 900;
            color: #1f2937;
            font-variant-numeric: tabular-nums;
            letter-spacing: -0.02em;
        }
        .timer-unit {
            color: #9ca3af;
            font-size: clamp(0.7rem, 1vw, 0.82rem);
            margin-top: 0.85rem;
            line-height: 1.7;
        }

        /* ── Footer ─────────────────────────────────────────────────────────── */
        .footer {
            color: #9ca3af;
            font-size: clamp(0.68rem, 0.95vw, 0.8rem);
            margin-top: 2rem;
            letter-spacing: 0.06em;
        }
    </style>
</head>
<body>

    <!-- Full-width banner: slides in from top 5 seconds before refresh -->
    <div class="refresh-banner" id="refreshBanner">
        &#x21BB;&ensp; QR code refreshing — please wait
        &ensp;/&ensp;
        QR குறியீடு புதுப்பிக்கப்படுகிறது — காத்திருக்கவும்
    </div>

    <!-- Error overlay with auto-retry countdown -->
    <div class="error-overlay" id="errorOverlay">
        <div class="error-card">
            <div class="error-icon">⚠️</div>
            <div class="error-title-en">Unable to load QR code</div>
            <div class="error-title-ta">QR குறியீட்டை ஏற்ற முடியவில்லை</div>
            <div class="error-hint">
                Check network connection and server status<br>
                இணைப்பு மற்றும் சேவையகத்தை சரிபார்க்கவும்
            </div>
            <div class="retry-label" id="retryLabel">Retrying in 5s…</div>
        </div>
    </div>

    <div class="container">

        <!-- Header: EN primary / Tamil secondary — clear hierarchy -->
        <div class="header">
            <div class="title-en">Scan QR Code</div>
            <div class="title-ta">QR குறியீட்டை ஸ்கேன் செய்யவும்</div>
            <div class="subtitle">
                Open your phone camera and point at the code to submit your grievance<br>
                புகார் படிவத்தை திறக்க உங்கள் மொபைல் கேமராவை QR குறியீட்டை நோக்கி சுட்டிக்காட்டவும்
            </div>
        </div>

        <!-- Three-column grid: instructions | QR | timer -->
        <div class="content-grid">

            <!-- Left: How to use -->
            <div class="instructions">
                <div class="instr-head-en">How to use</div>
                <div class="instr-head-ta">எப்படி பயன்படுத்துவது</div>
                <ul>
                    <li>
                        <span class="step-en">Open phone camera</span>
                        <span class="step-ta">கேமராவைத் திறக்கவும்</span>
                    </li>
                    <li>
                        <span class="step-en">Point at QR code</span>
                        <span class="step-ta">QR குறியீட்டை நோக்கவும்</span>
                    </li>
                    <li>
                        <span class="step-en">Tap the notification</span>
                        <span class="step-ta">அறிவிப்பைத் தட்டவும்</span>
                    </li>
                    <li>
                        <span class="step-en">Fill &amp; submit the form</span>
                        <span class="step-ta">படிவத்தை பூர்த்தி செய்யவும்</span>
                    </li>
                </ul>
            </div>

            <!-- Center: QR code -->
            <div class="qr-center">
                <div class="qr-card">
                    <div id="qrcode">
                        <div class="qr-loading">Generating…</div>
                    </div>
                </div>
            </div>

            <!-- Right: Countdown ring timer -->
            <div class="timer-container">
                <div class="timer-label-en">Valid for</div>
                <div class="timer-label-ta">செல்லுபடியாகும் நேரம்</div>
                <div class="timer-ring-wrap">
                    <svg class="timer-ring" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                        <circle class="ring-bg"       cx="60" cy="60" r="54"/>
                        <circle class="ring-progress" cx="60" cy="60" r="54" id="ringProgress"/>
                    </svg>
                    <div class="timer-number" id="timerNumber">{{ expiry_seconds }}</div>
                </div>
                <div class="timer-unit">seconds&ensp;/&ensp;விநாடிகள்</div>
            </div>

        </div>

        <div class="footer">Grievance Portal &nbsp;|&nbsp; குறைதீர்க்கும் போர்ட்டல்</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        const EXPIRY        = {{ expiry_seconds }};
        const CIRCUMFERENCE = 2 * Math.PI * 54; // 339.29px
        const VENUE_ID      = '{{ venue_id }}';

        let countdown  = EXPIRY;
        let retryTimer = null;
        let retrySecs  = 5;

        const timerNumEl    = document.getElementById('timerNumber');
        const ringEl        = document.getElementById('ringProgress');
        const refreshBanner = document.getElementById('refreshBanner');
        const errorOverlay  = document.getElementById('errorOverlay');
        const retryLabel    = document.getElementById('retryLabel');
        const qrContainer   = document.getElementById('qrcode');

        /* ── QR rendering ───────────────────────────────────────────────────── */
        function renderQR(url) {
            qrContainer.innerHTML = '';
            try {
                new QRCode(qrContainer, {
                    text: url,
                    width: 440,
                    height: 440,
                    colorDark: '#000000',
                    colorLight: '#ffffff',
                    correctLevel: QRCode.CorrectLevel.M,
                });
                hideError();
            } catch (e) {
                showError();
            }
        }

        /* ── Ring + number update ───────────────────────────────────────────── */
        function updateTimer() {
            const pct    = countdown / EXPIRY;
            const offset = CIRCUMFERENCE * (1 - pct);
            ringEl.style.strokeDashoffset = offset;
            timerNumEl.textContent = countdown;

            if (pct > 0.66)      ringEl.style.stroke = '#10b981'; // green
            else if (pct > 0.33) ringEl.style.stroke = '#f59e0b'; // amber
            else                 ringEl.style.stroke = '#ef4444'; // red
        }

        /* ── Error state ────────────────────────────────────────────────────── */
        function showError() {
            errorOverlay.classList.add('show');
            startRetryCountdown();
        }

        function hideError() {
            errorOverlay.classList.remove('show');
            if (retryTimer) { clearInterval(retryTimer); retryTimer = null; }
        }

        function startRetryCountdown() {
            retrySecs = 5;
            retryLabel.textContent = `Retrying in ${retrySecs}s…`;
            retryTimer = setInterval(() => {
                retrySecs--;
                retryLabel.textContent = retrySecs > 0
                    ? `Retrying in ${retrySecs}s…`
                    : 'Retrying…';
                if (retrySecs <= 0) {
                    clearInterval(retryTimer);
                    retryTimer = null;
                    retryFetchQR();
                }
            }, 1000);
        }

        async function retryFetchQR() {
            try {
                const res = await fetch(`/api/v1/qr/generate?venue_id=${encodeURIComponent(VENUE_ID)}`);
                if (!res.ok) throw new Error('Server error');
                const data = await res.json();
                const url  = window.location.origin + (data.verification_url || '');
                renderQR(url);
                countdown = EXPIRY;
                updateTimer();
            } catch {
                startRetryCountdown();
            }
        }

        /* ── Main countdown tick ────────────────────────────────────────────── */
        setInterval(() => {
            if (countdown > 0) {
                countdown--;
                updateTimer();
                if (countdown <= 5) refreshBanner.classList.add('show');
                if (countdown === 0) {
                    setTimeout(() => {
                        window.location.href =
                            window.location.pathname +
                            '?venue_id=' + encodeURIComponent(VENUE_ID) +
                            '&_t=' + Date.now();
                    }, 1000);
                }
            }
        }, 1000);

        /* ── Boot ───────────────────────────────────────────────────────────── */
        renderQR('{{ qr_url }}');
        updateTimer();
    </script>
</body>
</html>
