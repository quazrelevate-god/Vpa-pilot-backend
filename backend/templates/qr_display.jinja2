<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code - Grievance Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Mukta+Malar:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', 'Mukta Malar', sans-serif;
            background: #ffffff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            overflow: hidden;
        }

        .container {
            position: relative;
            width: 100%;
            max-width: 1200px;
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(40px) saturate(200%);
            -webkit-backdrop-filter: blur(40px) saturate(200%);
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15), inset 0 1px 1px rgba(255, 255, 255, 1);
            padding: 2rem;
            text-align: center;
        }

        /* ── Header ─────────────────────────────────────────────── */
        .header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 2rem;
            text-align: center;
        }

        .title-en {
            color: #1f2937;
            font-size: 1.75rem;
            font-weight: 800;
        }

        .title-ta {
            color: #1f2937;
            font-size: 1.4rem;
            font-weight: 700;
        }

        .subtitle-en {
            color: #6b7280;
            font-size: 0.9rem;
            margin-top: 0.35rem;
        }

        .subtitle-ta {
            color: #6b7280;
            font-size: 0.85rem;
        }

        /* ── Three-column content grid ──────────────────────────── */
        .content-grid {
            display: grid;
            grid-template-columns: 260px 1fr 260px;
            gap: 2rem;
            align-items: center;
            max-width: 1000px;
            margin: 0 auto;
        }

        /* ── QR card + code ─────────────────────────────────────── */
        .qr-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow:
                0 4px 6px -1px rgba(0, 0, 0, 0.07),
                0 10px 24px -4px rgba(0, 0, 0, 0.10),
                0 0 0 1px rgba(0, 0, 0, 0.04);
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        #qrcode {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 300px;
            height: 300px;
        }

        /* ── Instructions (left column) ─────────────────────────── */
        .instructions {
            background: rgba(16, 185, 129, 0.08);
            border: 2px solid #10b981;
            padding: 1.5rem;
            border-radius: 16px;
            text-align: left;
            align-self: center;
        }

        .instructions h3 {
            color: #065f46;
            font-size: 0.95rem;
            font-weight: 700;
            margin-bottom: 0.2rem;
        }

        .instructions h3 span {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #047857;
            margin-top: 0.1rem;
        }

        .instructions ul {
            list-style: none;
            padding: 0;
            margin-top: 1rem;
            color: #374151;
            font-size: 0.85rem;
        }

        .instructions li {
            margin-bottom: 0.8rem;
            padding-left: 1.5rem;
            position: relative;
            line-height: 1.4;
        }

        .instructions li:last-child {
            margin-bottom: 0;
        }

        .instructions li::before {
            content: "✓";
            position: absolute;
            left: 0;
            color: #10b981;
            font-weight: bold;
        }

        .instructions li .step-en {
            display: block;
            font-weight: 600;
            color: #1f2937;
        }

        .instructions li .step-ta {
            display: block;
            font-size: 0.78rem;
            color: #6b7280;
            margin-top: 0.05rem;
        }

        /* ── Timer (right column) ────────────────────────────────── */
        .timer-container {
            background: rgba(59, 130, 246, 0.08);
            border: 2px solid #3b82f6;
            padding: 2rem 1.5rem;
            border-radius: 16px;
            text-align: center;
            align-self: center;
        }

        .timer-label-en {
            color: #1e40af;
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 0.15rem;
        }

        .timer-label-ta {
            color: #1e40af;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .timer-display {
            font-size: 3.5rem;
            font-weight: 900;
            color: #1f2937;
            font-variant-numeric: tabular-nums;
            line-height: 1;
        }

        .timer-unit {
            color: #6b7280;
            font-size: 0.85rem;
            margin-top: 0.5rem;
            line-height: 1.6;
        }

        .refresh-message {
            background: rgba(245, 158, 11, 0.1);
            border: 1px solid rgba(245, 158, 11, 0.3);
            padding: 0.75rem 1rem;
            border-radius: 8px;
            margin-top: 1rem;
            display: none;
        }

        .refresh-message.show {
            display: block;
        }

        .refresh-text-en {
            color: #92400e;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .refresh-text-ta {
            color: #92400e;
            font-size: 0.8rem;
            margin-top: 0.1rem;
        }

        /* ── Footer ─────────────────────────────────────────────── */
        .footer-text {
            color: #6b7280;
            font-size: 0.82rem;
            margin-top: 2rem;
            text-align: center;
        }

        .loading {
            color: #6b7280;
            font-size: 1rem;
        }
    </style>
</head>
<body>
    <div class="container">

        <!-- Header: logo + bilingual title + subtitle -->
        <div class="header">
            <div class="title-en">Scan QR Code</div>
            <div class="title-ta">QR குறியீட்டை ஸ்கேன் செய்யவும்</div>
            <div class="subtitle-en">Scan with your mobile device to access the grievance form</div>
            <div class="subtitle-ta">புகார் படிவத்தை அணுக உங்கள் மொபைல் சாதனத்தில் ஸ்கேன் செய்யவும்</div>
        </div>

        <!-- Three-column grid: instructions | QR | timer -->
        <div class="content-grid">

            <!-- Left: How to use -->
            <div class="instructions">
                <h3>
                    How to use
                    <span>எப்படி பயன்படுத்துவது</span>
                </h3>
                <ul>
                    <li>
                        <span class="step-en">Open phone camera</span>
                        <span class="step-ta">கேமராவைத் திறக்கவும்</span>
                    </li>
                    <li>
                        <span class="step-en">Point at QR code</span>
                        <span class="step-ta">QR குறியீட்டை நோக்கவும்</span>
                    </li>
                    <li>
                        <span class="step-en">Tap notification</span>
                        <span class="step-ta">அறிவிப்பைத் தட்டவும்</span>
                    </li>
                    <li>
                        <span class="step-en">Fill the form</span>
                        <span class="step-ta">படிவத்தை பூர்த்தி செய்யவும்</span>
                    </li>
                </ul>
            </div>

            <!-- Center: QR Code -->
            <div style="display:flex;justify-content:center;">
                <div class="qr-card">
                    <div id="qrcode">
                        <div id="qr-loading" class="loading">Generating...</div>
                    </div>
                </div>
            </div>

            <!-- Right: Timer -->
            <div class="timer-container">
                <div class="timer-label-en">Valid for</div>
                <div class="timer-label-ta">செல்லுபடியாகும்</div>
                <div class="timer-display" id="timer">60</div>
                <div class="timer-unit">seconds<br>விநாடிகள்</div>
                <div class="refresh-message" id="refreshMessage">
                    <div class="refresh-text-en">Refreshing...</div>
                    <div class="refresh-text-ta">புதுப்பிக்கப்படுகிறது...</div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer-text">
            Grievance Portal &nbsp;|&nbsp; குறைதீர்க்கும் போர்ட்டல்
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        const EXPIRY = {{ expiry_seconds }};
        let countdown = EXPIRY;

        // Clear "Generating..." placeholder, then render QR
        const qrContainer = document.getElementById('qrcode');
        qrContainer.innerHTML = '';
        new QRCode(qrContainer, {
            text: '{{ qr_url }}',
            width: 300,
            height: 300,
            colorDark: '#000000',
            colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.H
        });

        // Hide the "Generating..." placeholder once the QR image appears
        const loadingEl = document.getElementById('qr-loading');
        const observer = new MutationObserver(() => {
            if (qrContainer.querySelector('img, canvas')) {
                loadingEl.style.display = 'none';
                observer.disconnect();
            }
        });
        observer.observe(qrContainer, { childList: true, subtree: true });

        // Countdown timer
        const timerEl = document.getElementById('timer');
        const refreshMsg = document.getElementById('refreshMessage');

        function updateTimerColor() {
            // Calculate color from green (100%) to red (0%)
            const percentage = (countdown / EXPIRY) * 100;
            let color;
            
            if (percentage > 66) {
                // Green zone (100% - 66%)
                color = '#10b981'; // green
            } else if (percentage > 33) {
                // Yellow/Orange zone (66% - 33%)
                color = '#f59e0b'; // orange
            } else if (percentage > 0) {
                // Red zone (33% - 0%)
                color = '#ef4444'; // red
            } else {
                // Expired
                color = '#dc2626'; // dark red
            }
            
            timerEl.style.color = color;
        }

        setInterval(() => {
            if (countdown > 0) {
                countdown--;
                timerEl.textContent = countdown;
                updateTimerColor();
                
                if (countdown <= 5) refreshMsg.classList.add('show');
                
                if (countdown === 0) {
                    setTimeout(() => window.location.href = window.location.pathname + '?venue_id=' + encodeURIComponent('{{ venue_id }}') + '&_t=' + Date.now(), 1000);
                }
            }
        }, 1000);
        
        // Initial color
        updateTimerColor();
    </script>
</body>
</html>
