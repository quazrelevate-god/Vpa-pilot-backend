<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>Referral Booking</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Mukta+Malar:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', 'Mukta Malar', sans-serif;
            background: #f1f5f9; min-height: 100vh;
            padding: 1rem; max-width: 480px; margin: 0 auto;
        }
        .header {
            background: linear-gradient(135deg, #0d9488, #0f766e);
            color: white; border-radius: 14px; padding: 1.1rem 1.25rem; margin-bottom: 1rem;
            display: flex; align-items: center; justify-content: space-between;
        }
        .header-title { font-size: 1.05rem; font-weight: 800; }
        .header-sub   { font-size: 0.78rem; opacity: 0.9; margin-top: 0.15rem; }
        .lang-pill {
            display: flex; align-items: center; gap: 0.4rem;
            background: rgba(255,255,255,0.18); border-radius: 50px;
            padding: 0.25rem 0.65rem; font-size: 0.72rem; font-weight: 700; flex-shrink: 0;
        }
        .sw { position:relative; display:inline-block; width:30px; height:16px; }
        .sw input { opacity:0; width:0; height:0; }
        .sl { position:absolute; cursor:pointer; inset:0; background:rgba(255,255,255,0.35); border-radius:16px; transition:.25s; }
        .sl:before { position:absolute; content:""; height:10px; width:10px; left:3px; bottom:3px; background:white; border-radius:50%; transition:.25s; }
        input:checked + .sl { background:rgba(255,255,255,0.55); }
        input:checked + .sl:before { transform:translateX(14px); }

        .date-banner {
            background: #ecfdf5; border:1px solid #a7f3d0; color:#065f46;
            border-radius: 10px; padding: 0.6rem 0.9rem; margin-bottom: 1rem;
            font-size: 0.85rem; font-weight: 600; text-align:center;
        }
        .card { background:white; border-radius:14px; box-shadow:0 1px 4px rgba(0,0,0,0.07); padding:1.1rem; margin-bottom:1rem; }
        .fld { margin-bottom: 0.9rem; }
        .fld:last-child { margin-bottom: 0; }
        .lbl { display:block; font-size:0.8rem; font-weight:700; color:#374151; margin-bottom:0.35rem; }
        .lbl .req { color:#ef4444; }
        .inp {
            width:100%; padding:0.65rem 0.85rem; border:1.5px solid #e2e8f0; border-radius:9px;
            font-size:0.9rem; font-family:inherit; background:#f8fafc; color:#1e293b; outline:none; transition:border-color .15s;
        }
        .inp:focus { border-color:#0d9488; background:white; }
        select.inp { appearance:auto; }

        .slot-msg { font-size:0.8rem; color:#6b7280; margin-bottom:0.5rem; }
        .slot-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:0.5rem; }

        .submit-btn {
            width:100%; padding:0.85rem; background:linear-gradient(135deg, #0d9488, #0f766e);
            color:white; border:none; border-radius:11px; font-size:0.98rem; font-weight:800; cursor:pointer;
            display:flex; align-items:center; justify-content:center; gap:0.5rem; font-family:inherit; transition:opacity .2s;
        }
        .submit-btn:disabled { opacity:0.45; cursor:not-allowed; }

        .err-box { background:#fee2e2; color:#991b1b; border-radius:8px; padding:0.6rem 0.85rem; font-size:0.82rem; font-weight:600; margin-bottom:0.75rem; display:none; }

        .success-box { background:linear-gradient(135deg, #059669, #0d9488); color:white; border-radius:14px; padding:1.5rem; text-align:center; display:none; }
        .success-box .s-token { font-size:1.5rem; font-weight:900; letter-spacing:0.02em; margin:0.4rem 0 0.2rem; word-break:break-all; }
        .success-box .s-row { font-size:0.85rem; opacity:0.95; margin-top:0.25rem; }

        .ta { display:none; }
        body.ta-mode .en { display:none; }
        body.ta-mode .ta { display:initial; }
    </style>
</head>
<body>
    <div class="header">
        <div>
            <div class="header-title"><span class="en">🤝 Referral Booking</span><span class="ta">🤝 பரிந்துரை பதிவு</span></div>
            <div class="header-sub"><span class="en">Book your meeting slot (11 AM – 1 PM)</span><span class="ta">உங்கள் சந்திப்பு நேரத்தை பதிவு செய்யவும் (காலை 11 – மதியம் 1)</span></div>
        </div>
        <div class="lang-pill">
            <span>EN</span>
            <label class="sw"><input type="checkbox" id="lt" onchange="setLang(this.checked)" checked><span class="sl"></span></label>
            <span>த</span>
        </div>
    </div>

    <div class="date-banner">
        <i class="fa-solid fa-calendar-day"></i>
        <span class="en">Booking for: </span><span class="ta">பதிவு தேதி: </span>
        <strong>{{ date_label }}</strong>
    </div>

    <div class="err-box" id="errBox"></div>

    <div class="success-box" id="successBox">
        <div style="font-size:2rem;">✅</div>
        <div class="en" style="font-weight:800;font-size:1rem;">Referral Booked!</div>
        <div class="ta" style="font-weight:800;font-size:1rem;">பரிந்துரை பதிவு செய்யப்பட்டது!</div>
        <div class="s-token" id="sToken">REF—</div>
        <div class="s-row" id="sSlot"></div>
        <div class="s-row en">Please arrive 10 minutes early.</div>
        <div class="s-row ta">10 நிமிடங்களுக்கு முன் வருகை தரவும்.</div>
    </div>

    <div id="mainForm">
        <div class="card">
            <div class="fld">
                <label class="lbl"><span class="en">Full Name</span><span class="ta">முழு பெயர்</span> <span class="req">*</span></label>
                <input type="text" id="fName" class="inp" placeholder="Enter full name / முழு பெயர்" oninput="validate()">
            </div>
            <div class="fld">
                <label class="lbl">
                    <span class="en">Mobile Number</span><span class="ta">அலைபேசி எண்</span>
                    <span style="color:#94a3b8;font-weight:400;font-size:0.75rem;"> (<span class="en">optional</span><span class="ta">விரும்பினால்</span>)</span>
                </label>
                <input type="tel" id="fMobile" class="inp" maxlength="10" placeholder="10-digit mobile (optional)" oninput="this.value=this.value.replace(/[^0-9]/g,'')">
            </div>
            <div class="fld">
                <label class="lbl"><span class="en">Number of Persons</span><span class="ta">நபர்களின் எண்ணிக்கை</span> <span class="req">*</span></label>
                <select id="fPersons" class="inp" onchange="onPersonsChange()">
                    <option value="1">1 — Just me / நான் மட்டும்</option>
                    <option value="2">2 Persons / 2 நபர்கள்</option>
                    <option value="3">3 Persons / 3 நபர்கள்</option>
                </select>
            </div>
            <div class="fld">
                <label class="lbl"><span class="en">Referred By</span><span class="ta">பரிந்துரைத்தவர்</span> <span class="req">*</span></label>
                <input type="text" id="fRefBy" class="inp" placeholder="Name of person who referred you / பரிந்துரைத்தவரின் பெயர்" oninput="validate()">
            </div>
            <div class="fld" style="margin-bottom:0;">
                <label class="lbl"><span class="en">Reason for Meeting</span><span class="ta">சந்திப்பின் காரணம்</span> <span class="req">*</span></label>
                <textarea id="fReason" class="inp" rows="3"
                    placeholder="Briefly describe the purpose of your visit / உங்கள் வருகையின் நோக்கத்தை சுருக்கமாக விவரிக்கவும்"
                    style="resize:vertical; min-height:72px;"
                    oninput="validate()"></textarea>
            </div>
        </div>

        <div class="card">
            <label class="lbl"><i class="fa-solid fa-clock"></i> <span class="en">Select a Time Slot</span><span class="ta">நேரத்தைத் தேர்ந்தெடுக்கவும்</span> <span class="req">*</span></label>
            <div class="slot-msg" id="slotMsg"></div>
            <div class="slot-grid" id="slotGrid"></div>
            <input type="hidden" id="selSlotId">
        </div>

        <button class="submit-btn" id="subBtn" disabled onclick="submitReferral()">
            <i class="fa-solid fa-paper-plane"></i>
            <span class="en">Confirm Booking</span><span class="ta">பதிவை உறுதிசெய்யவும்</span>
        </button>
    </div>

    <script>
    const TOKEN = "{{ token }}";
    let slotsData = [];
    let slotRefreshTimer = null;

    function setLang(ta) {
        document.body.classList.toggle('ta-mode', ta);
        try { localStorage.setItem('vpa_lang', ta ? 'ta' : 'en'); } catch(e) {}
    }
    (function(){ let l='ta'; try{ l=localStorage.getItem('vpa_lang')||'ta'; }catch(e){} document.getElementById('lt').checked=l==='ta'; setLang(l==='ta'); })();

    function showErr(m){ const e=document.getElementById('errBox'); e.textContent=m; e.style.display='block'; setTimeout(()=>e.style.display='none',5000); }

    async function loadSlots() {
        const grid = document.getElementById('slotGrid');
        const msg  = document.getElementById('slotMsg');
        const ta   = document.body.classList.contains('ta-mode');
        try {
            const res  = await fetch('/api/v1/referral/slots?d=' + encodeURIComponent(TOKEN));
            const data = await res.json();
            slotsData = data.slots || [];

            if (!data.slots || data.slots.length === 0) {
                grid.innerHTML = '';
                msg.innerHTML = '<span style="color:#b45309;">⚠ ' + (ta ? 'இன்று நேரங்கள் எதுவும் கிடைக்கவில்லை.' : 'No slots open for today.') + '</span>';
                return;
            }

            const now = new Date();
            const nowMin = now.getHours()*60 + now.getMinutes();
            const selId = document.getElementById('selSlotId').value;
            const persons = parseInt(document.getElementById('fPersons').value, 10) || 1;

            msg.textContent = ta ? 'பச்சை = கிடைக்கிறது, மஞ்சள் = நிரம்பிக்கொண்டிருக்கிறது, சிவப்பு = நிரம்பியது'
                                 : 'green = available, amber = filling up, red = full';
            grid.innerHTML = '';

            data.slots.forEach(slot => {
                const [sh, sm] = slot.start.split(':').map(Number);
                const isPast = (sh*60+sm) <= nowMin;
                const isFull = !isPast && (slot.remaining === 0 || slot.status === 'FULL' || slot.remaining < persons);
                const isPartial = !isPast && !isFull && slot.available && slot.booked_count > 0;
                const isOpen = !isPast && !isFull && slot.available && slot.booked_count === 0;
                const bookable = isPartial || isOpen;
                const isSel = String(slot.id) === String(selId);

                let bg, border, cursor, opacity, dot, sub;
                if (isPast)        { bg='#f1f5f9'; border='#cbd5e1'; cursor='not-allowed'; opacity='0.4'; dot='⬜'; sub=(ta?'முடிந்தது':'Passed'); }
                else if (isFull)   { bg='#fee2e2'; border='#fca5a5'; cursor='not-allowed'; opacity='0.7'; dot='🔴'; sub=(ta?'நிரம்பியது':'Full'); }
                else if (isPartial){ bg='#fef3c7'; border=isSel?'#0d9488':'#fbbf24'; cursor='pointer'; opacity='1'; dot='🟠'; sub=slot.remaining+' '+(ta?'மீதம்':'left'); }
                else               { bg='#dcfce7'; border=isSel?'#0d9488':'#86efac'; cursor='pointer'; opacity='1'; dot='🟢'; sub=(ta?'கிடைக்கிறது':'Available'); }

                const card = document.createElement('div');
                card.style.cssText = `border-radius:8px;padding:0.55rem 0.5rem;border:2px solid ${border};cursor:${cursor};background:${bg};opacity:${opacity};text-align:center;${isSel&&bookable?'outline:2.5px solid #0d9488;outline-offset:1px;':''}`;
                card.innerHTML = `<div style="font-size:0.78rem;font-weight:700;color:#1e293b;">${dot} ${slot.start} – ${slot.end}</div><div style="font-size:0.7rem;font-weight:600;color:#64748b;margin-top:2px;">${sub}</div>`;
                if (bookable) card.addEventListener('click', () => selectSlot(slot.id, slot.label, card));
                else if (isSel) { document.getElementById('selSlotId').value=''; validate(); }
                grid.appendChild(card);
            });
        } catch(e) {
            msg.textContent = ta ? 'நேரங்களை ஏற்ற முடியவில்லை.' : 'Failed to load slots.';
        }
    }

    function selectSlot(id, label, el) {
        document.querySelectorAll('#slotGrid > div').forEach(c => c.style.outline='none');
        el.style.outline = '2.5px solid #0d9488'; el.style.outlineOffset='1px';
        document.getElementById('selSlotId').value = id;
        validate();
    }

    function onPersonsChange() { loadSlots(); validate(); }

    function validate() {
        const ok = document.getElementById('fName').value.trim()
                 && document.getElementById('fRefBy').value.trim()
                 && document.getElementById('fReason').value.trim()
                 && document.getElementById('selSlotId').value;
        document.getElementById('subBtn').disabled = !ok;
    }

    async function submitReferral() {
        const btn = document.getElementById('subBtn');
        const ta  = document.body.classList.contains('ta-mode');
        const name   = document.getElementById('fName').value.trim();
        const refBy  = document.getElementById('fRefBy').value.trim();
        const reason = document.getElementById('fReason').value.trim();
        const slotId = document.getElementById('selSlotId').value;
        if (!name || !refBy || !reason || !slotId) return;

        btn.disabled = true;
        btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> ${ta?'பதிவு செய்கிறது…':'Booking…'}`;
        try {
            const fd = new FormData();
            fd.append('d', TOKEN);
            fd.append('name', name);
            fd.append('referred_by', refBy);
            fd.append('reason', reason);
            fd.append('num_persons', document.getElementById('fPersons').value);
            fd.append('slot_id', slotId);
            fd.append('mobile', document.getElementById('fMobile').value.trim());
            const res = await fetch('/api/v1/referral/submit', { method:'POST', body:fd });
            const data = await res.json();
            if (res.ok) {
                if (slotRefreshTimer) clearInterval(slotRefreshTimer);
                document.getElementById('sToken').textContent = data.token_display || ('REF'+data.token_number);
                document.getElementById('sSlot').textContent = (ta?'நேரம்: ':'Slot: ') + (data.slot_label || '');
                document.getElementById('mainForm').style.display='none';
                document.getElementById('successBox').style.display='block';
                window.scrollTo({ top:0, behavior:'smooth' });
            } else {
                showErr(data.error || (ta?'பதிவு தோல்வி.':'Booking failed.'));
                // Slot may have filled — refresh grid
                loadSlots();
                btn.disabled = false;
                btn.innerHTML = `<i class="fa-solid fa-paper-plane"></i> ${ta?'பதிவை உறுதிசெய்யவும்':'Confirm Booking'}`;
            }
        } catch(e) {
            showErr(ta?'பிணைய பிழை.':'Network error.');
            btn.disabled = false;
            btn.innerHTML = `<i class="fa-solid fa-paper-plane"></i> ${ta?'பதிவை உறுதிசெய்யவும்':'Confirm Booking'}`;
        }
    }

    loadSlots();
    slotRefreshTimer = setInterval(loadSlots, 8000);  // reflect admin block/close in near-real-time
    </script>
</body>
</html>
