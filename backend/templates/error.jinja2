<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Grievance Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Mukta+Malar:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', 'Mukta Malar', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem 1rem;
            background: #f1f5f9;
            background-image:
                radial-gradient(ellipse 80% 50% at 50% -10%, rgba(0,135,4,0.08), transparent),
                radial-gradient(ellipse 60% 40% at 80% 100%, rgba(239,68,68,0.06), transparent);
        }

        .card {
            width: 100%;
            max-width: 440px;
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(40px) saturate(180%);
            -webkit-backdrop-filter: blur(40px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.85);
            border-radius: 20px;
            padding: 2.5rem 1.75rem 2rem;
            text-align: center;
            box-shadow:
                0 20px 50px -15px rgba(0, 0, 0, 0.1),
                0 8px 20px -8px rgba(0, 0, 0, 0.06),
                inset 0 1px 1px rgba(255, 255, 255, 0.9);
        }

        /* ── Language toggle ───────────────────────────────────── */
        .lang-bar {
            display: flex;
            justify-content: center;
            margin-bottom: 2rem;
        }
        .lang-seg {
            display: inline-flex;
            gap: 4px;
            background: rgba(0,0,0,0.05);
            border-radius: 999px;
            padding: 3px;
        }
        .lang-seg button {
            border: none;
            background: transparent;
            font-family: inherit;
            font-size: 0.82rem;
            font-weight: 700;
            color: #64748b;
            padding: 0.4rem 1.2rem;
            border-radius: 999px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .lang-seg button.active {
            background: #fff;
            color: #0f172a;
            box-shadow: 0 1px 4px rgba(0,0,0,0.1);
        }

        /* ── Error icon ────────────────────────────────────────── */
        .error-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(185, 28, 28, 0.08);
            border: 2px solid rgba(185, 28, 28, 0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            font-size: 1.8rem;
            color: #b91c1c;
        }

        /* ── Error message ─────────────────────────────────────── */
        .error-msg {
            font-size: 1rem;
            font-weight: 600;
            color: #1e293b;
            line-height: 1.5;
            margin-bottom: 1.75rem;
            padding: 0 0.5rem;
        }

        /* ── Divider ───────────────────────────────────────────── */
        .divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(0,0,0,0.08), transparent);
            margin-bottom: 1.5rem;
        }

        /* ── What to do next ───────────────────────────────────── */
        .next-heading {
            font-size: 0.95rem;
            font-weight: 800;
            color: #3b82f6;
            margin-bottom: 1rem;
            text-align: left;
        }

        .next-list {
            list-style: none;
            text-align: left;
            display: flex;
            flex-direction: column;
            gap: 1.1rem;
            margin-bottom: 1.5rem;
            counter-reset: steps;
        }
        .next-list li {
            counter-increment: steps;
            display: flex;
            align-items: baseline;
            gap: 0.6rem;
            font-size: 0.9rem;
            color: #475569;
            line-height: 1.5;
        }
        .next-list li::before {
            content: counter(steps) ".";
            flex-shrink: 0;
            color: #3b82f6;
            font-size: 0.95rem;
            font-weight: 800;
        }

        /* ── Footer ────────────────────────────────────────────── */
        .footer {
            font-size: 0.75rem;
            color: #94a3b8;
            margin-top: 0.5rem;
        }

        /* ── Language visibility ────────────────────────────────── */
        .tamil { display: none; }
        body.tamil-mode .english { display: none; }
        body.tamil-mode .tamil { display: block; }
        body.tamil-mode .next-list .tamil { display: flex; }
    </style>
</head>
<body>
    <div class="card">
        <!-- Language switcher -->
        <div class="lang-bar">
            <div class="lang-seg">
                <button type="button" id="langBtnEn" onclick="setLang(false)">English</button>
                <button type="button" id="langBtnTa" class="active" onclick="setLang(true)">தமிழ்</button>
            </div>
        </div>

        <!-- Error icon -->
        <div class="error-icon" id="errorIconWrap">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>

        <!-- Single-line error message -->
        <div class="error-msg english" id="error-msg-en">Something went wrong</div>
        <div class="error-msg tamil" id="error-msg-ta">ஏதோ தவறு ஏற்பட்டது</div>

        <div class="divider"></div>

        <!-- What to do next -->
        <div class="next-heading english">What to do next</div>
        <div class="next-heading tamil">அடுத்து என்ன செய்வது</div>

        <ol class="next-list english" id="steps-en">
            <li>Scan a new QR code to start fresh</li>
            <li>Complete the form within the time limit</li>
            <li>Contact support if the issue persists</li>
        </ol>
        <ol class="next-list tamil" id="steps-ta">
            <li>புதிய QR குறியீட்டை ஸ்கேன் செய்யவும்</li>
            <li>நேரத்திற்குள் படிவத்தை நிரப்பவும்</li>
            <li>சிக்கல் தொடர்ந்தால் உதவியைத் தொடர்பு கொள்ளவும்</li>
        </ol>

        <div class="footer english">Grievance Portal</div>
        <div class="footer tamil">குறைதீர்க்கும் போர்ட்டல்</div>
    </div>

    <script>
        var urlParams = new URLSearchParams(window.location.search);
        var errorType = urlParams.get('type') || 'unknown';
        var errorMessage = urlParams.get('message') || '';

        var errors = {
            session_expired: {
                en: 'Your session has expired. Please scan a new QR code.',
                ta: 'உங்கள் அமர்வு காலாவதியானது. புதிய QR ஐ ஸ்கேன் செய்யவும்.'            },
            session_used: {
                en: 'This QR code has already been used.',
                ta: 'இந்த QR குறியீடு ஏற்கனவே பயன்படுத்தப்பட்டது.'            },
            session_not_found: {
                en: 'Session not found. Please scan a new QR code.',
                ta: 'அமர்வு கிடைக்கவில்லை. புதிய QR ஐ ஸ்கேன் செய்யவும்.'            },
            device_mismatch: {
                en: 'This form can only be opened on the device that scanned the QR code.',
                ta: 'QR ஐ ஸ்கேன் செய்த சாதனத்தில் மட்டுமே இதைத் திறக்க முடியும்.'            },
            qr_expired: {
                en: 'This QR code has expired.',
                ta: 'இந்த QR குறியீடு காலாவதியானது.'            },
            unknown: {
                en: errorMessage || 'Something went wrong. Please try again.',
                ta: errorMessage || 'ஏதோ தவறு ஏற்பட்டது. மீண்டும் முயற்சிக்கவும்.'            }
        };

        var data = errors[errorType] || errors['unknown'];
        document.getElementById('error-msg-en').textContent = data.en;
        document.getElementById('error-msg-ta').textContent = data.ta;


        function setLang(isTamil) {
            if (isTamil) {
                document.body.classList.add('tamil-mode');
            } else {
                document.body.classList.remove('tamil-mode');
            }
            document.getElementById('langBtnEn').classList.toggle('active', !isTamil);
            document.getElementById('langBtnTa').classList.toggle('active', isTamil);
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.body.classList.add('tamil-mode');
        });
    </script>
</body>
</html>
