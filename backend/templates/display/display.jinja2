<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
    <title>Crowd Board — Today's Visitors</title>

    <!-- PWA -->
    <link rel="manifest" href="/display/manifest.webmanifest">
    <meta name="theme-color" content="#0c2e59">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Crowd Board">
    <link rel="apple-touch-icon" href="/static/assets/apple-touch-icon.png">
    <link rel="icon" href="/static/assets/icon-192.png">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Mukta+Malar:wght@500;600;700&display=swap" rel="stylesheet">
    <style>
        :root{
            --navy:#0c2e59; --navy-2:#103a73;
            --teal:#0d9488; --teal-700:#0f766e;
            --green:#059669; --green-bg:#ecfdf5; --green-bd:#a7f3d0;
            --red:#dc2626;  --red-bg:#fef2f2;  --red-bd:#fecaca;
            --blue:#2563eb; --blue-bg:#eff6ff; --blue-bd:#bfdbfe;
            --violet:#7c3aed; --violet-bg:#f5f3ff; --violet-bd:#ddd6fe;
            --amber:#b45309; --amber-bg:#fffbeb; --amber-bd:#fde68a;
            --ink:#0f172a; --muted:#64748b; --line:#e2e8f0; --bg:#f1f5f9;
        }
        *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
        body{font-family:'Inter','Mukta Malar',system-ui,sans-serif;background:var(--bg);color:var(--ink);
            min-height:100vh;padding-bottom:env(safe-area-inset-bottom);}
        .ta{display:none;} body.ta-mode .en{display:none;} body.ta-mode .ta{display:inline;}

        /* Header */
        header{background:var(--navy);color:#fff;position:sticky;top:0;z-index:20;
            padding:calc(0.7rem + env(safe-area-inset-top)) 1rem 0.7rem;
            box-shadow:0 2px 10px rgba(0,0,0,.18);}
        .h-row{display:flex;align-items:center;justify-content:space-between;gap:.5rem;}
        .h-title{font-size:1.05rem;font-weight:800;line-height:1.1;}
        .h-date{font-size:.72rem;opacity:.7;margin-top:.1rem;}
        .h-actions{display:flex;align-items:center;gap:.4rem;flex-shrink:0;}
        .chip{background:rgba(255,255,255,.12);border:none;color:#fff;font-family:inherit;
            border-radius:9px;padding:.4rem .6rem;font-size:.72rem;font-weight:700;cursor:pointer;
            display:flex;align-items:center;gap:.3rem;transition:background .15s;}
        .chip:active{background:rgba(255,255,255,.25);}
        .clock{font-variant-numeric:tabular-nums;font-weight:700;font-size:.8rem;opacity:.9;}

        /* Tabs */
        .tabs{display:flex;gap:.35rem;background:rgba(255,255,255,.1);border-radius:11px;padding:.25rem;margin-top:.7rem;}
        .tab{flex:1;text-align:center;padding:.5rem;border-radius:8px;font-size:.85rem;font-weight:700;
            color:rgba(255,255,255,.75);cursor:pointer;transition:.15s;border:none;background:transparent;font-family:inherit;}
        .tab.active{background:#fff;color:var(--navy);}
        .tab .cnt{font-size:.7rem;opacity:.7;font-weight:600;}

        /* Body */
        main{max-width:560px;margin:0 auto;padding:.85rem;}
        .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;margin-bottom:.85rem;}
        .stat{background:#fff;border:1px solid var(--line);border-radius:12px;padding:.6rem .5rem;text-align:center;}
        .stat .n{font-size:1.4rem;font-weight:900;line-height:1;}
        .stat .l{font-size:.66rem;color:var(--muted);font-weight:600;margin-top:.2rem;}
        .stat.s-exp .n{color:var(--blue);} .stat.s-pre .n{color:var(--green);} .stat.s-no .n{color:var(--red);}

        .search{position:relative;margin-bottom:.85rem;}
        .search input{width:100%;padding:.7rem .9rem .7rem 2.3rem;border:1.5px solid var(--line);border-radius:11px;
            font-size:1rem;font-family:inherit;background:#fff;outline:none;}
        .search input:focus{border-color:var(--teal);}
        .search svg{position:absolute;left:.75rem;top:50%;transform:translateY(-50%);width:1.05rem;height:1.05rem;color:var(--muted);}

        /* Cards */
        .list{display:flex;flex-direction:column;gap:.6rem;}
        .card{background:#fff;border:1px solid var(--line);border-radius:14px;padding:.85rem;box-shadow:0 1px 3px rgba(0,0,0,.04);}
        .card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem;}
        .c-time{display:inline-flex;align-items:center;gap:.3rem;background:var(--navy);color:#fff;border-radius:7px;
            padding:.2rem .5rem;font-size:.74rem;font-weight:800;font-variant-numeric:tabular-nums;flex-shrink:0;}
        .c-name{font-size:1.02rem;font-weight:800;line-height:1.2;}
        .c-sub{font-size:.78rem;color:var(--muted);margin-top:.15rem;display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;}
        .c-count{display:inline-flex;align-items:center;gap:.25rem;background:#f1f5f9;border-radius:6px;padding:.1rem .4rem;font-weight:700;color:#334155;}
        .c-call{display:inline-flex;align-items:center;gap:.3rem;color:var(--teal-700);font-weight:700;text-decoration:none;}
        .c-reason{font-size:.8rem;color:#475569;margin-top:.45rem;line-height:1.4;
            display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
        .pill{font-size:.68rem;font-weight:800;border-radius:50px;padding:.2rem .55rem;white-space:nowrap;border:1px solid transparent;}
        .pill.expected{background:var(--blue-bg);color:var(--blue);border-color:var(--blue-bd);}
        .pill.resch{background:var(--violet-bg);color:var(--violet);border-color:var(--violet-bd);}
        .pill.present{background:var(--green-bg);color:var(--green);border-color:var(--green-bd);}
        .pill.notcame{background:var(--red-bg);color:var(--red);border-color:var(--red-bd);}
        .pill.pending{background:#f8fafc;color:var(--muted);border-color:var(--line);}

        .actions{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-top:.75rem;}
        .btn{padding:.6rem;border-radius:10px;font-size:.88rem;font-weight:800;font-family:inherit;cursor:pointer;
            border:1.5px solid var(--line);background:#fff;color:#475569;display:flex;align-items:center;justify-content:center;gap:.35rem;transition:.12s;}
        .btn:active{transform:scale(.97);}
        .btn.came.on{background:var(--green);border-color:var(--green);color:#fff;}
        .btn.no.on{background:var(--red);border-color:var(--red);color:#fff;}
        .btn[disabled]{opacity:.55;cursor:default;}

        .empty{text-align:center;padding:3rem 1rem;color:var(--muted);}
        .empty svg{width:3rem;height:3rem;opacity:.35;margin-bottom:.6rem;}
        .skeleton{height:96px;border-radius:14px;background:linear-gradient(90deg,#eef2f7 25%,#e2e8f0 37%,#eef2f7 63%);
            background-size:400% 100%;animation:sh 1.3s ease infinite;}
        @keyframes sh{0%{background-position:100% 0;}100%{background-position:-100% 0;}}
        .toast{position:fixed;left:50%;bottom:calc(1rem + env(safe-area-inset-bottom));transform:translateX(-50%);
            background:var(--ink);color:#fff;padding:.6rem 1rem;border-radius:10px;font-size:.82rem;font-weight:600;
            opacity:0;pointer-events:none;transition:opacity .2s;z-index:50;}
        .toast.show{opacity:.95;}
        .offline{background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber-bd);border-radius:10px;
            padding:.5rem .8rem;font-size:.78rem;font-weight:700;text-align:center;margin-bottom:.75rem;display:none;}
    </style>
</head>
<body>
    <header>
        <div class="h-row">
            <div>
                <div class="h-title"><span class="en">Today's Visitors</span><span class="ta">இன்றைய வருகையாளர்கள்</span></div>
                <div class="h-date" id="dateLabel"></div>
            </div>
            <div class="h-actions">
                <!-- Live meeting-slot availability. Loads today's real slots; -->
                <!-- shows a clear "no slots" state so floor staff see it at a glance. -->
                <span id="slotChip"
                      title="Meeting slot availability"
                      style="display:inline-flex;align-items:center;gap:.35rem;font-weight:800;font-size:.72rem;padding:.4rem .6rem;border-radius:9px;border:none;background:rgba(255,255,255,.12);color:#fff;">
                    <span id="slotChipDot" style="width:.5rem;height:.5rem;border-radius:999px;background:#94a3b8;display:inline-block;"></span>
                    <span id="slotChipText">…</span>
                </span>
                <span class="clock" id="clock"></span>
                <button class="chip" id="installBtn" style="display:none;">⬇ <span class="en">Install</span><span class="ta">நிறுவு</span></button>
                <button class="chip" id="langToggle">தமிழ்</button>
                <a class="chip" href="/display/logout"><span class="en">Exit</span><span class="ta">வெளியேறு</span></a>
            </div>
        </div>
        <div class="tabs">
            <button class="tab active" data-tab="appt">
                <div><span class="en">Appointments</span><span class="ta">சந்திப்புகள்</span></div>
                <div class="cnt" id="cntAppt"></div>
            </button>
            <button class="tab" data-tab="ref">
                <div><span class="en">Referrals</span><span class="ta">பரிந்துரைகள்</span></div>
                <div class="cnt" id="cntRef"></div>
            </button>
        </div>
    </header>

    <main>
        <div class="offline" id="offlineBar">
            <span class="en">Offline — showing last loaded data. Status changes need a connection.</span>
            <span class="ta">இணைப்பு இல்லை — பழைய தரவு காட்டப்படுகிறது. நிலை மாற்ற இணைப்பு தேவை.</span>
        </div>

        <div class="stats">
            <div class="stat s-exp"><div class="n" id="stExpected">0</div><div class="l"><span class="en">Expected</span><span class="ta">எதிர்பார்ப்பு</span></div></div>
            <div class="stat s-pre"><div class="n" id="stPresent">0</div><div class="l"><span class="en">Came</span><span class="ta">வந்தவர்</span></div></div>
            <div class="stat s-no"><div class="n" id="stNo">0</div><div class="l"><span class="en">Not Came</span><span class="ta">வரவில்லை</span></div></div>
        </div>

        <div class="search">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/></svg>
            <input id="searchInput" placeholder="Search name / mobile / token" autocomplete="off">
        </div>

        <div class="list" id="list"></div>
    </main>

    <div class="toast" id="toast"></div>

    <!-- Floating: register a walk-in visitor (petition or appointment) -->
    <button id="addPetBtn" aria-label="Add visitor"
      style="position:fixed;right:16px;bottom:calc(18px + env(safe-area-inset-bottom));z-index:55;display:flex;align-items:center;gap:.35rem;background:var(--navy);color:#fff;border:none;border-radius:999px;padding:.85rem 1.2rem;font-weight:800;font-size:.98rem;box-shadow:0 8px 22px rgba(15,23,42,.35);cursor:pointer;">
      <span style="font-size:1.35rem;line-height:.7;font-weight:700;">+</span>
      <span class="en">Add</span><span class="ta">சேர்</span>
    </button>

    <!-- Unified walk-in intake bottom sheet -->
    <div id="petSheet" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:70;align-items:flex-end;">
      <div style="background:#fff;width:100%;max-width:560px;margin:0 auto;border-radius:18px 18px 0 0;padding:1.1rem 1.15rem calc(1.2rem + env(safe-area-inset-bottom));max-height:94vh;overflow:auto;">
        <div style="width:40px;height:4px;background:#cbd5e1;border-radius:4px;margin:0 auto .85rem;"></div>

        <!-- ── View 1: intake form ── -->
        <div id="intakeView">
        <div style="font-weight:800;font-size:1.1rem;margin-bottom:.9rem;">
          <span class="en">New walk-in visitor</span><span class="ta">புதிய நேரடி வருகையாளர்</span>
        </div>
        <form id="petForm" style="display:flex;flex-direction:column;gap:.8rem;">
          <label style="font-weight:700;font-size:.78rem;color:#475569;text-transform:uppercase;letter-spacing:.04em;">
            <span class="en">Name</span><span class="ta">பெயர்</span>
            <input id="petName" name="name" required autocomplete="off"
              style="display:block;width:100%;box-sizing:border-box;margin-top:.35rem;padding:.7rem .85rem;border:1.5px solid #cbd5e1;border-radius:12px;font-size:1rem;font-weight:500;text-transform:none;letter-spacing:normal;color:#0f172a;" />
          </label>
          <label style="font-weight:700;font-size:.78rem;color:#475569;text-transform:uppercase;letter-spacing:.04em;">
            <span class="en">Mobile (optional)</span><span class="ta">கைபேசி (விருப்பம்)</span>
            <input id="petMobile" name="mobile" inputmode="numeric" autocomplete="off"
              style="display:block;width:100%;box-sizing:border-box;margin-top:.35rem;padding:.7rem .85rem;border:1.5px solid #cbd5e1;border-radius:12px;font-size:1rem;font-weight:500;text-transform:none;letter-spacing:normal;color:#0f172a;" />
          </label>
          <label style="font-weight:700;font-size:.78rem;color:#475569;text-transform:uppercase;letter-spacing:.04em;">
            <span class="en">Category</span><span class="ta">வகை</span>
            <select id="petCategory" required
              style="display:block;width:100%;box-sizing:border-box;margin-top:.35rem;padding:.7rem .85rem;border:1.5px solid #cbd5e1;border-radius:12px;font-size:1rem;font-weight:500;text-transform:none;letter-spacing:normal;color:#0f172a;background:#fff;">
              <option value="" disabled selected>— Select —</option>
              <option value="action_required">Action Required</option>
              <option value="proposals">Proposals</option>
              <option value="transfer_requests">Transfer Request</option>
              <option value="pension_requests">Pension Request</option>
              <option value="school_admission">School Admission</option>
              <option value="job_requests">Job Request</option>
              <option value="rti">RTI</option>
              <option value="associations_unions">Associations / Unions</option>
              <option value="school_upgradation">School Upgradation</option>
              <option value="invitation">Invitation</option>
              <option value="greetings">Greetings</option>
              <option value="general">General</option>
              <option value="other">Other</option>
            </select>
          </label>
          <label style="font-weight:700;font-size:.78rem;color:#475569;text-transform:uppercase;letter-spacing:.04em;">
            <span class="en">Grievance (write the issue)</span><span class="ta">குறை (எழுதவும்)</span>
            <textarea id="petDesc" name="description" rows="2"
              style="display:block;width:100%;box-sizing:border-box;margin-top:.35rem;padding:.7rem .85rem;border:1.5px solid #cbd5e1;border-radius:12px;font-size:1rem;font-weight:500;text-transform:none;letter-spacing:normal;color:#0f172a;resize:vertical;"></textarea>
          </label>
          <label style="font-weight:700;font-size:.78rem;color:#475569;text-transform:uppercase;letter-spacing:.04em;">
            <span class="en">Photo(s) (optional)</span><span class="ta">புகைப்படம் (விருப்பம்)</span>
            <input id="petFiles" name="files" type="file" accept="image/*,application/pdf" capture="environment" multiple
              style="display:block;width:100%;box-sizing:border-box;margin-top:.35rem;padding:.55rem;border:1.5px dashed #94a3b8;border-radius:12px;font-size:.9rem;font-weight:500;text-transform:none;letter-spacing:normal;background:#f8fafc;" />
          </label>
          <div id="petFileInfo" style="font-size:.85rem;color:#64748b;font-weight:600;"></div>

          <!-- Meeting slots — always shown (live availability) -->
          <div style="border-top:1px solid #e2e8f0;padding-top:.7rem;margin-top:.2rem;">
            <div style="font-weight:800;font-size:.9rem;color:#0f172a;margin-bottom:.15rem;">
              <span class="en">Book a meeting (optional)</span><span class="ta">சந்திப்பு பதிவு (விருப்பம்)</span>
            </div>
            <div style="font-size:.76rem;color:#64748b;margin-bottom:.5rem;">
              <span class="en">Pick a date &amp; time. Leave empty to submit as a petition only.</span>
              <span class="ta">தேதி &amp; நேரம் தேர்ந்தெடுக்கவும். இல்லையெனில் மனுவாக மட்டும் சமர்ப்பிக்கவும்.</span>
            </div>
            <div id="petDates" style="display:flex;gap:.45rem;overflow-x:auto;padding-bottom:.4rem;"></div>
            <div id="petSlotMsg" style="font-size:.84rem;font-weight:600;margin:.35rem 0;"></div>
            <div id="petSlots" style="display:grid;grid-template-columns:1fr 1fr;gap:.45rem;"></div>
            <div id="petPersonsWrap" style="display:none;align-items:center;gap:.6rem;margin-top:.6rem;">
              <span style="font-size:.78rem;font-weight:700;color:#475569;text-transform:uppercase;"><span class="en">Persons</span><span class="ta">நபர்கள்</span></span>
              <button type="button" id="petPMinus" class="btn" style="padding:.3rem .8rem;">−</button>
              <b id="petPersons" style="font-size:1.05rem;min-width:1.2rem;text-align:center;">1</b>
              <button type="button" id="petPPlus" class="btn" style="padding:.3rem .8rem;">+</button>
            </div>
          </div>

          <div style="display:flex;gap:.6rem;margin-top:.4rem;">
            <button type="button" id="petCancel" class="btn" style="flex:1;">
              <span class="en">Cancel</span><span class="ta">ரத்து</span>
            </button>
            <button type="submit" id="petSubmit" class="btn" style="flex:2;background:var(--navy);color:#fff;border-color:var(--navy);">
              <span id="petSubmitLabelPet"><span class="en">Submit petition</span><span class="ta">மனு சமர்ப்பி</span></span>
              <span id="petSubmitLabelAppt" style="display:none;"><span class="en">Book appointment</span><span class="ta">சந்திப்பு பதிவு</span></span>
            </button>
          </div>
        </form>
        </div>

        <!-- ── View 2: ticket / success ── -->
        <div id="ticketView" style="display:none;text-align:center;padding:.5rem 0 .3rem;">
          <div style="width:64px;height:64px;border-radius:999px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;margin:.4rem auto 1rem;font-size:2rem;">✓</div>
          <div style="font-size:.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.05em;"><span class="en">Token</span><span class="ta">டோக்கன்</span></div>
          <div id="ticketToken" style="font-size:2rem;font-weight:900;color:#0f172a;margin:.15rem 0 .6rem;letter-spacing:.02em;">—</div>
          <div id="ticketStatus" style="display:inline-block;font-size:.95rem;font-weight:700;padding:.5rem 1rem;border-radius:12px;margin-bottom:1.2rem;"></div>
          <button type="button" id="ticketDone" class="btn" style="width:100%;background:var(--navy);color:#fff;border-color:var(--navy);">
            <span class="en">Done</span><span class="ta">முடிந்தது</span>
          </button>
        </div>
      </div>
    </div>

    <!-- iOS install instructions -->
    <div id="iosSheet" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:60;align-items:flex-end;">
      <div style="background:#fff;width:100%;max-width:560px;margin:0 auto;border-radius:18px 18px 0 0;padding:1.25rem 1.25rem calc(1.5rem + env(safe-area-inset-bottom));">
        <div style="width:40px;height:4px;background:#cbd5e1;border-radius:4px;margin:0 auto .9rem;"></div>
        <div style="font-weight:800;font-size:1.05rem;margin-bottom:.6rem;">
          <span class="en">Install on your phone</span><span class="ta">தொலைபேசியில் நிறுவவும்</span>
        </div>
        <ol style="margin:0 0 1rem 1.1rem;font-size:.9rem;color:#334155;line-height:1.9;">
          <li><span class="en">Tap the <b>Share</b> button <span style="font-size:1.1em;">&#x2191;</span> in Safari</span><span class="ta"><b>Share</b> பொத்தானை அழுத்தவும்</span></li>
          <li><span class="en">Choose <b>Add to Home Screen</b></span><span class="ta"><b>Add to Home Screen</b> தேர்ந்தெடுக்கவும்</span></li>
          <li><span class="en">Tap <b>Add</b></span><span class="ta"><b>Add</b> அழுத்தவும்</span></li>
        </ol>
        <button class="btn" style="width:100%;background:var(--navy);color:#fff;border-color:var(--navy);" onclick="document.getElementById('iosSheet').style.display='none'">
          <span class="en">Got it</span><span class="ta">சரி</span>
        </button>
      </div>
    </div>

    <script>
    const TAB = { appt: 'appt', ref: 'ref' };
    let currentTab = 'appt';
    let cache = { appt: [], ref: [] };
    let lastSummary = { appt: {}, ref: {} };
    let lang = 'en';

    // ── i18n ──
    function applyLang(){
        document.body.classList.toggle('ta-mode', lang === 'ta');
        document.getElementById('langToggle').textContent = lang === 'ta' ? 'EN' : 'தமிழ்';
        const si = document.getElementById('searchInput');
        si.placeholder = lang === 'ta' ? 'பெயர் / எண் / டோக்கன் தேடுங்கள்' : 'Search name / mobile / token';
        try { localStorage.setItem('cb_lang', lang); } catch(e){}
        render();
    }
    document.getElementById('langToggle').addEventListener('click', () => { lang = lang === 'ta' ? 'en' : 'ta'; applyLang(); });
    (function(){ try { lang = localStorage.getItem('cb_lang') || 'en'; } catch(e){} })();

    // ── Clock ──
    function tick(){
        const d = new Date();
        document.getElementById('clock').textContent =
            d.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', hour12:true });
    }
    setInterval(tick, 1000); tick();

    // ── Tabs ──
    document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => {
        currentTab = t.dataset.tab;
        document.querySelectorAll('.tab').forEach(x => x.classList.toggle('active', x === t));
        render();
        load(currentTab);
    }));

    document.getElementById('searchInput').addEventListener('input', render);

    function toast(msg){
        const el = document.getElementById('toast');
        el.textContent = msg; el.classList.add('show');
        clearTimeout(el._t); el._t = setTimeout(() => el.classList.remove('show'), 2200);
    }
    function setOffline(on){ document.getElementById('offlineBar').style.display = on ? 'block' : 'none'; }

    // ── Data ──
    async function load(tab){
        const url = tab === 'appt' ? '/display/api/today' : '/display/api/referral/today';
        try {
            const res = await fetch(url, { headers: { 'Accept':'application/json' } });
            if (!res.ok) throw new Error('http '+res.status);
            const data = await res.json();
            cache[tab] = data.items || [];
            lastSummary[tab] = data;
            setOffline(false);
            render();
            updateCounts();
        } catch(e){
            setOffline(true);
        }
    }

    function updateCounts(){
        document.getElementById('cntAppt').textContent = lastSummary.appt.total != null ? lastSummary.appt.total : '';
        document.getElementById('cntRef').textContent  = lastSummary.ref.total  != null ? lastSummary.ref.total  : '';
    }

    function esc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

    function render(){
        const list = document.getElementById('list');
        const items = cache[currentTab] || [];
        const q = document.getElementById('searchInput').value.trim().toLowerCase();
        const filtered = !q ? items : items.filter(it =>
            (it.name||'').toLowerCase().includes(q) ||
            (it.mobile||'').includes(q) ||
            (it.token||'').toLowerCase().includes(q) ||
            (it.referred_by||'').toLowerCase().includes(q)
        );

        // summary stats from server payload
        const sum = lastSummary[currentTab] || {};
        document.getElementById('stExpected').textContent = sum.expected ?? 0;
        document.getElementById('stPresent').textContent  = sum.present  ?? 0;
        document.getElementById('stNo').textContent       = sum.not_came ?? 0;
        document.getElementById('dateLabel').textContent  = sum.date || '';

        if (!items.length){
            list.innerHTML = '<div class="empty"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4z"/></svg><div>'
                + (lang==='ta' ? 'இன்னும் வருகையாளர்கள் இல்லை' : 'No visitors yet for today') + '</div></div>';
            return;
        }
        if (!filtered.length){
            list.innerHTML = '<div class="empty">'+(lang==='ta'?'பொருத்தம் இல்லை':'No matches')+'</div>';
            return;
        }
        list.innerHTML = filtered.map(it => currentTab === 'appt' ? apptCard(it) : refCard(it)).join('');
    }

    // ── Appointment card ──
    function apptCard(it){
        const db = it.status_db;
        const pill = db === 'AWAITING_REVIEW'
              ? `<span class="pill present">${lang==='ta'?'வந்தார்':'Came'}</span>`
            : db === 'NOT_CAME'
              ? `<span class="pill notcame">${lang==='ta'?'வரவில்லை':'Not Came'}</span>`
            : db === 'RESCHEDULED'
              ? `<span class="pill resch">${lang==='ta'?'மறுதிட்டம்':'Rescheduled'}</span>`
              : `<span class="pill expected">${lang==='ta'?'எதிர்பார்ப்பு':'Expected'}</span>`;
        const came = db === 'AWAITING_REVIEW', no = db === 'NOT_CAME';
        const mobile = it.mobile && it.mobile !== '—'
            ? `<a class="c-call" href="tel:${esc(it.mobile)}">📞 ${esc(it.mobile)}</a>` : '';
        return `<div class="card" data-id="${it.id}">
            <div class="card-top">
              <div style="min-width:0;">
                <div class="c-name">${esc(it.name)}</div>
                <div class="c-sub">
                  <span class="c-count">👥 ${it.num_persons||1}</span>
                  ${mobile}
                  ${it.category ? `<span>${esc(it.category)}</span>` : ''}
                </div>
              </div>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:.35rem;flex-shrink:0;">
                ${it.time ? `<span class="c-time">🕑 ${esc(it.time)}</span>` : ''}
                ${pill}
              </div>
            </div>
            <div class="actions">
              <button class="btn came ${came?'on':''}" onclick="mark('appt',${it.id},'came')" title="${came?'Tap again to undo':''}">${came?'✓':'✓'} <span class="en">${came?'Came ↺':'Came'}</span><span class="ta">${came?'வந்தார் ↺':'வந்தார்'}</span></button>
              <button class="btn no ${no?'on':''}" onclick="mark('appt',${it.id},'notcame')" title="${no?'Tap again to undo':''}">✕ <span class="en">${no?'Not Came ↺':'Not Came'}</span><span class="ta">${no?'வரவில்லை ↺':'வரவில்லை'}</span></button>
            </div>
        </div>`;
    }

    // ── Referral card ──
    function refCard(it){
        const s = it.status;
        const pill = s === 'CAME'
              ? `<span class="pill present">${lang==='ta'?'வந்தார்':'Came'}</span>`
            : s === 'NOT_CAME'
              ? `<span class="pill notcame">${lang==='ta'?'வரவில்லை':'Not Came'}</span>`
              : `<span class="pill pending">${lang==='ta'?'காத்திருப்பு':'Pending'}</span>`;
        const came = s === 'CAME', no = s === 'NOT_CAME';
        const mobile = it.mobile
            ? `<a class="c-call" href="tel:${esc(it.mobile)}">📞 ${esc(it.mobile)}</a>` : '';
        return `<div class="card" data-id="${it.id}">
            <div class="card-top">
              <div style="min-width:0;">
                <div class="c-name">${esc(it.name)}</div>
                <div class="c-sub">
                  <span class="c-count">👥 ${it.num_persons||1}</span>
                  ${mobile}
                  <span>${lang==='ta'?'பரிந்துரை':'Ref'}: ${esc(it.referred_by)}</span>
                </div>
              </div>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:.35rem;flex-shrink:0;">
                ${it.slot ? `<span class="c-time">🕑 ${esc(it.slot_start||'')}</span>` : ''}
                ${pill}
              </div>
            </div>
            ${it.reason ? `<div class="c-reason">${esc(it.reason)}</div>` : ''}
            <div class="actions">
              <button class="btn came ${came?'on':''}" onclick="mark('ref',${it.id},'came')" title="${came?'Tap again to undo':''}">✓ <span class="en">${came?'Came ↺':'Came'}</span><span class="ta">${came?'வந்தார் ↺':'வந்தார்'}</span></button>
              <button class="btn no ${no?'on':''}" onclick="mark('ref',${it.id},'notcame')" title="${no?'Tap again to undo':''}">✕ <span class="en">${no?'Not Came ↺':'Not Came'}</span><span class="ta">${no?'வரவில்லை ↺':'வரவில்லை'}</span></button>
            </div>
        </div>`;
    }

    // ── Mark attendance (optimistic, toggle-to-revert) ──
    // target is 'came' or 'notcame'. Tapping the button that is already active
    // reverts the row to its original "expected" state (undo a mistaken tap).
    async function mark(tab, id, target){
        const item = (cache[tab]||[]).find(x => String(x.id) === String(id));
        if (!item) return;

        const isAppt = tab === 'appt';
        const cur = isAppt ? item.status_db : item.status;   // current state
        const activeCame = isAppt ? (cur === 'AWAITING_REVIEW') : (cur === 'CAME');
        const activeNo   = (cur === 'NOT_CAME');
        const alreadyThis = (target === 'came' && activeCame) || (target === 'notcame' && activeNo);

        // Decide payload + optimistic new state
        let payload, newState;
        if (alreadyThis){                       // revert
            payload = isAppt ? 'Reset' : 'PENDING';
            newState = isAppt ? 'SCHEDULED' : 'PENDING';
        } else if (target === 'came'){
            payload = isAppt ? 'Came' : 'CAME';
            newState = isAppt ? 'AWAITING_REVIEW' : 'CAME';
        } else {
            payload = isAppt ? 'Not Came' : 'NOT_CAME';
            newState = 'NOT_CAME';
        }

        // optimistic update
        if (isAppt) item.status_db = newState; else item.status = newState;
        render();

        const url = isAppt
            ? `/display/api/appointments/${id}/status`
            : `/display/api/referral/${id}/status`;
        try {
            const res = await fetch(url, {
                method:'PATCH', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ status: payload })
            });
            if (!res.ok) throw new Error('http '+res.status);
            toast(alreadyThis ? (lang==='ta'?'மீட்டமைக்கப்பட்டது':'Reverted')
                              : (lang==='ta'?'புதுப்பிக்கப்பட்டது':'Updated'));
            load(tab);
        } catch(e){
            toast(lang==='ta' ? 'இணைப்பு இல்லை — மீண்டும் முயற்சிக்கவும்' : 'Offline — try again');
            load(tab);
        }
    }

    // ── Boot ──
    function showSkeleton(){
        document.getElementById('list').innerHTML =
            Array.from({length:4}).map(()=>'<div class="skeleton"></div>').join('');
    }
    applyLang();
    showSkeleton();
    load('appt');
    load('ref');                       // warm the other tab's count
    setInterval(() => load(currentTab), 12000);  // live refresh
    document.addEventListener('visibilitychange', () => { if (!document.hidden) load(currentTab); });
    window.addEventListener('online',  () => { setOffline(false); load(currentTab); });
    window.addEventListener('offline', () => setOffline(true));

    // ── PWA service worker ──
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/display/service-worker.js', { scope: '/display/' })
                .catch(() => {/* non-fatal */});
        });
    }

    // ── Install (Add to Home Screen) ──
    const installBtn = document.getElementById('installBtn');
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches
        || window.navigator.standalone === true;
    const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent) && !window.MSStream;
    let deferredPrompt = null;

    // Android/desktop Chrome: capture the native prompt and reveal the button.
    window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        if (!isStandalone) installBtn.style.display = 'flex';
    });

    // iOS Safari has no prompt event — show the button so users get instructions.
    if (isIOS && !isStandalone) installBtn.style.display = 'flex';

    // Already installed → never show.
    if (isStandalone) installBtn.style.display = 'none';

    installBtn.addEventListener('click', async () => {
        if (deferredPrompt) {
            deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            deferredPrompt = null;
            if (outcome === 'accepted') installBtn.style.display = 'none';
        } else if (isIOS) {
            document.getElementById('iosSheet').style.display = 'flex';
        } else {
            toast(lang==='ta' ? 'உலாவி மெனுவில் "நிறுவு" தேர்வு செய்யவும்' : 'Use the browser menu → Install');
        }
    });

    window.addEventListener('appinstalled', () => {
        installBtn.style.display = 'none';
        toast(lang==='ta' ? 'நிறுவப்பட்டது' : 'Installed');
    });

    // ── Header: live meeting-slot availability chip ──
    // Polls today's real slots so the floor team can see availability at a glance
    // without opening the intake sheet. If today isn't open OR no slots are open,
    // shows a clear "No slots today" amber state.
    async function refreshSlotChip(){
        const chip = document.getElementById('slotChip');
        const dot  = document.getElementById('slotChipDot');
        const txt  = document.getElementById('slotChipText');
        function paint(bg, color, dotBg, text){
            chip.style.backgroundColor = bg;
            chip.style.color = color;
            dot.style.backgroundColor = dotBg;
            txt.textContent = text;
        }
        try {
            const today = new Date();
            const y = today.getFullYear(), m = String(today.getMonth()+1).padStart(2,'0'), d = String(today.getDate()).padStart(2,'0');
            const r = await fetch('/api/v1/scheduling/slots/available?target_date=' + `${y}-${m}-${d}`);
            const data = await r.json();
            const slots = data.slots || [];
            const open = slots.filter(s => s.available && s.remaining > 0);
            const totalRemaining = open.reduce((a,s) => a + s.remaining, 0);
            if (!open.length){
                paint('#fef3c7','#78350f','#f59e0b',
                    (lang==='ta' ? 'இன்று இடம் இல்லை' : 'No slots today'));
            } else {
                paint('#dcfce7','#14532d','#16a34a',
                    (lang==='ta' ? `${totalRemaining} இடம் மீதம்` : `${totalRemaining} seats · ${open.length} slots`));
            }
        } catch(e){
            paint('#f1f5f9','#64748b','#94a3b8', (lang==='ta' ? 'இணைப்பு இல்லை' : 'Offline'));
        }
    }
    refreshSlotChip();
    setInterval(refreshSlotChip, 30000);          // live refresh
    document.addEventListener('visibilitychange', () => { if (!document.hidden) refreshSlotChip(); });
    // Keep the chip in sync with the language toggle
    document.getElementById('langToggle').addEventListener('click', () => setTimeout(refreshSlotChip, 30));

    // ── Unified walk-in intake (petition + appointment booking) ──
    const petSheet = document.getElementById('petSheet');
    const petForm  = document.getElementById('petForm');
    let petSelectedSlot = null, petSelectedDate = null, petPersonsN = 1, petSlotTimer = null;

    function updatePetSubmitLabel(){
        const appt = !!petSelectedSlot;
        document.getElementById('petSubmitLabelPet').style.display  = appt ? 'none' : 'inline';
        document.getElementById('petSubmitLabelAppt').style.display = appt ? 'inline' : 'none';
    }

    async function loadPetDates(){
        const wrap = document.getElementById('petDates'), msg = document.getElementById('petSlotMsg');
        try {
            const r = await fetch('/api/v1/scheduling/open-dates', { headers:{'Accept':'application/json'} });
            const dates = await r.json();
            if (!Array.isArray(dates) || !dates.length){
                wrap.innerHTML=''; document.getElementById('petSlots').innerHTML='';
                msg.innerHTML = '<span style="color:#b45309;">'+(lang==='ta'?'திறந்த தேதிகள் இல்லை':'No open dates for meetings')+'</span>';
                return;
            }
            wrap.innerHTML = dates.map(d =>
                `<button type="button" class="petDateChip" data-date="${d.date}" style="flex:0 0 auto;padding:.5rem .8rem;border:1.5px solid #cbd5e1;border-radius:12px;background:#fff;color:#0f172a;font-weight:700;font-size:.82rem;white-space:nowrap;cursor:pointer;">${esc(d.date_label)}</button>`
            ).join('');
            wrap.querySelectorAll('.petDateChip').forEach(b => b.addEventListener('click', () => selectPetDate(b.dataset.date)));
            selectPetDate(dates[0].date);
        } catch(e){ msg.textContent = lang==='ta'?'இணைப்பு இல்லை':'Offline'; }
    }

    function selectPetDate(date){
        petSelectedDate = date; petSelectedSlot = null;
        document.getElementById('petPersonsWrap').style.display = 'none';
        updatePetSubmitLabel();
        document.querySelectorAll('.petDateChip').forEach(b => {
            const on = b.dataset.date === date;
            b.style.background = on ? 'var(--navy)' : '#fff';
            b.style.color = on ? '#fff' : '#0f172a';
            b.style.borderColor = on ? 'var(--navy)' : '#cbd5e1';
        });
        loadPetSlots();
    }

    async function loadPetSlots(){
        if (!petSelectedDate) return;
        const grid = document.getElementById('petSlots'), msg = document.getElementById('petSlotMsg');
        try {
            const r = await fetch('/api/v1/scheduling/slots/available?target_date=' + petSelectedDate, { headers:{'Accept':'application/json'} });
            const data = await r.json();
            const slots = data.slots || [];
            const openCount = slots.filter(s => s.available && s.remaining > 0).length;
            msg.innerHTML = openCount
                ? '<span style="color:#16a34a;">'+openCount+' '+(lang==='ta'?'நேரங்கள் கிடைக்கும்':'time slots open')+'</span>'
                : '<span style="color:#b45309;font-weight:700;">⚠ '+(lang==='ta'?'இந்த நாளில் இடம் இல்லை':'No slots available for this day')+'</span>';
            grid.innerHTML = slots.map(s => {
                const open = s.available && s.remaining > 0, sel = petSelectedSlot === s.id;
                const bg = sel?'#ecfdf5':open?'#f0fdf4':'#f8fafc';
                const bd = sel?'#059669':open?'#86efac':'#e5e9f0';
                const sub = open ? (s.remaining+'/'+s.max_capacity+' '+(lang==='ta'?'இடம்':'left'))
                    : (s.status==='BLOCKED' ? (lang==='ta'?'மூடப்பட்டது':'Blocked') : (lang==='ta'?'நிரம்பியது':'Full'));
                return `<button type="button" class="petSlotCard" data-id="${s.id}" ${open?'':'disabled'} style="text-align:left;padding:.5rem .6rem;border:1.5px solid ${bd};border-radius:12px;background:${bg};cursor:${open?'pointer':'not-allowed'};opacity:${open?1:.65};">
                    <div style="font-size:.8rem;font-weight:800;color:${open?'#0f172a':'#94a3b8'};">${esc(s.label)}</div>
                    <div style="font-size:.7rem;font-weight:700;color:${open?'#16a34a':'#94a3b8'};">${sub}</div>
                </button>`;
            }).join('');
            grid.querySelectorAll('.petSlotCard').forEach(b => { if (!b.disabled) b.addEventListener('click', () => selectPetSlot(Number(b.dataset.id))); });
        } catch(e){ msg.textContent = lang==='ta'?'இணைப்பு இல்லை':'Offline'; }
    }

    function selectPetSlot(id){
        petSelectedSlot = (petSelectedSlot === id) ? null : id;
        document.getElementById('petPersonsWrap').style.display = petSelectedSlot ? 'flex' : 'none';
        updatePetSubmitLabel();
        loadPetSlots();
    }

    document.getElementById('petPMinus').addEventListener('click', () => { petPersonsN = Math.max(1, petPersonsN-1); document.getElementById('petPersons').textContent = petPersonsN; });
    document.getElementById('petPPlus').addEventListener('click',  () => { petPersonsN = Math.min(4, petPersonsN+1); document.getElementById('petPersons').textContent = petPersonsN; });

    function openPetSheet(){
        petForm.reset();
        document.getElementById('petFileInfo').textContent = '';
        petSelectedSlot = null; petSelectedDate = null; petPersonsN = 1;
        document.getElementById('petPersons').textContent = '1';
        document.getElementById('petPersonsWrap').style.display = 'none';
        document.getElementById('intakeView').style.display = 'block';
        document.getElementById('ticketView').style.display = 'none';
        updatePetSubmitLabel();
        petSheet.style.display = 'flex';
        loadPetDates();
        clearInterval(petSlotTimer);
        petSlotTimer = setInterval(() => { if (petSelectedDate) loadPetSlots(); }, 5000);
        setTimeout(() => document.getElementById('petName').focus(), 50);
    }
    function closePetSheet(){ petSheet.style.display = 'none'; clearInterval(petSlotTimer); }

    document.getElementById('addPetBtn').addEventListener('click', openPetSheet);
    document.getElementById('petCancel').addEventListener('click', closePetSheet);
    document.getElementById('ticketDone').addEventListener('click', closePetSheet);
    petSheet.addEventListener('click', (e) => { if (e.target === petSheet) closePetSheet(); });
    document.getElementById('petFiles').addEventListener('change', (e) => {
        const n = e.target.files.length;
        document.getElementById('petFileInfo').textContent = n ? (lang==='ta' ? `${n} படம்` : `${n} file(s) selected`) : '';
    });

    function showTicket(d){
        clearInterval(petSlotTimer);
        document.getElementById('ticketToken').textContent = d.token_display || '—';
        const st = document.getElementById('ticketStatus');
        if (d.status === 'SCHEDULED'){
            st.style.background='#dcfce7'; st.style.color='#15803d';
            st.textContent = (lang==='ta'?'சந்திப்பு · ':'Scheduled · ') + (d.scheduled_date||'') + ' ' + (d.scheduled_time||'');
        } else if (d.status === 'WAITING'){
            st.style.background='#fef3c7'; st.style.color='#b45309';
            st.textContent = (lang==='ta'?'காத்திருப்பு வரிசையில் சேர்க்கப்பட்டது':'Added to waiting queue');
        } else {
            st.style.background='#e0e7ff'; st.style.color='#4338ca';
            st.textContent = (lang==='ta'?'மனு சமர்ப்பிக்கப்பட்டது':'Petition submitted');
        }
        document.getElementById('intakeView').style.display = 'none';
        document.getElementById('ticketView').style.display = 'block';
        load('appt');
    }

    petForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = document.getElementById('petName').value.trim();
        const category = document.getElementById('petCategory').value;
        const desc = document.getElementById('petDesc').value.trim();
        const files = document.getElementById('petFiles').files;
        if (!name)     { toast(lang==='ta' ? 'பெயர் தேவை' : 'Name is required'); return; }
        if (!category) { toast(lang==='ta' ? 'வகை தேர்ந்தெடுக்கவும்' : 'Select a category'); return; }
        if (!petSelectedSlot && !desc && !files.length){
            toast(lang==='ta' ? 'குறை எழுதவும், படம் அல்லது நேரம் தேர்ந்தெடுக்கவும்' : 'Write the grievance, add a photo, or pick a slot'); return;
        }
        const btn = document.getElementById('petSubmit'); const orig = btn.innerHTML;
        btn.disabled = true; btn.textContent = (lang==='ta' ? 'பதிவு...' : 'Saving…');
        const fd = new FormData();
        fd.append('name', name);
        fd.append('mobile', document.getElementById('petMobile').value.trim());
        fd.append('category', category);
        fd.append('description', desc);
        fd.append('schedule_meeting', petSelectedSlot ? 'true' : 'false');
        if (petSelectedSlot){ fd.append('slot_id', petSelectedSlot); fd.append('num_persons', petPersonsN); }
        for (const f of files) fd.append('files', f);
        try {
            const res = await fetch('/display/api/intake', { method: 'POST', body: fd });
            const d = await res.json().catch(() => ({}));
            if (!res.ok) throw new Error(d.detail || d.error || ('http ' + res.status));
            showTicket(d);
        } catch(err) {
            toast(lang==='ta' ? 'தோல்வி — மீண்டும் முயற்சிக்கவும்' : 'Failed — check connection & retry');
        } finally {
            btn.disabled = false; btn.innerHTML = orig;
        }
    });
    </script>
</body>
</html>
