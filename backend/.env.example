# Database Configuration
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/citizen_scheduler

# Security Configuration
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars

# QR Code Configuration (in seconds)
QR_EXPIRY_SECONDS=300

# Session Configuration (in seconds)
SESSION_EXPIRY_SECONDS=1800

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Frontend Configuration
FRONTEND_FORM_BASE_URL=http://localhost:3000/form

# Application Configuration
APP_NAME=Citizen Scheduler API
APP_VERSION=1.0.0
DEBUG=False

# File Upload Configuration
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_EXTENSIONS=.pdf,.jpg,.jpeg,.png

# Display Board Credentials
DISPLAY_USERNAME=display
DISPLAY_PASSWORD=display123

# Staff Dashboard Credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123

# MLA Profile (used by init_db.py seeder)
MLA_NAME=Default MLA
MLA_CONSTITUENCY=Default Constituency
MLA_CONTACT_MOBILE=
MLA_CONTACT_EMAIL=
MLA_OFFICE_ADDRESS=

# AI Configuration
GOOGLE_API_KEY=your-google-genai-api-key

# APM SMS Configuration
APM_SMS_API_KEY=your-apm-sms-api-key
